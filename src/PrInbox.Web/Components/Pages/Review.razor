@page "/review"
@rendermode InteractiveServer
@using System.Collections.Generic
@using System.IO
@using System.Linq
@using PrInbox.Core.Findings
@using PrInbox.Core.Models
@using PrInbox.Core.Storage
@using PrInbox.Publishers
@using PrInbox.Web.Services
@inject ReviewRunStore Runs
@inject ReviewPublishOrchestrator Orchestrator
@inject PrSnapshotRepository SnapRepo
@inject InboxState State
@inject PullRequestRepository PrRepo
@inject IJSRuntime Js
@inject ILogger<Review> Log
@inject NavigationManager Nav
@implements IDisposable

<h1>Review findings</h1>

@if (string.IsNullOrWhiteSpace(Url))
{
    <p class="empty">Missing <code>?url=</code> parameter.</p>
    return;
}

<div class="toolbar">
    <a href="/" class="muted">← back to inbox</a>
    <span>&nbsp;·&nbsp;</span>
    <button type="button"
            class="link-like done-and-back"
            title="Mark this PR as Done at the current head, then return to the inbox."
            disabled="@_actionBusy"
            @onclick="OnDoneAndBackAsync">
        ✓ Mark done &amp; back
    </button>
    <span>&nbsp;·&nbsp;</span>
    <button type="button"
            class="link-like review-flag @(_inboxRow?.IsFlagged == true ? "is-on" : "")"
            title="@(_inboxRow?.IsFlagged == true ? "Unflag — remove from 'of interest'." : "Flag as 'of interest'.")"
            aria-pressed="@(_inboxRow?.IsFlagged == true ? "true" : "false")"
            disabled="@_actionBusy"
            @onclick="OnToggleFlagAsync">
        @(_inboxRow?.IsFlagged == true ? "★ Flagged" : "☆ Flag")
    </button>
    <span>&nbsp;·&nbsp;</span>
    <a href="@Url" target="_blank" rel="noopener">@Url</a>
    @if (IsGitHubUrl)
    {
        <span>&nbsp;·&nbsp;</span>
        <a href="@($"/threads?url={Uri.EscapeDataString(Url ?? string.Empty)}")"
           title="Manage and resolve review threads">
            Manage threads
        </a>
    }
    @if (_run is not null && _run.Findings is not null)
    {
        <span>&nbsp;·&nbsp;</span>
        <button type="button" class="link-like" @onclick="OnOpenFindingsYaml"
                title="Open findings.yaml in your default editor. Save the file to update the UI.">
            Open findings.yaml
        </button>
    }
</div>

@if (!string.IsNullOrEmpty(_actionMessage))
{
    <div class="action-error" role="alert">@_actionMessage</div>
}

    @if (_run is not null && _drift is not null
         && (_drift.Kind == DriftKind.Ahead || _drift.Kind == DriftKind.ForcePushed))
    {
        var compareUrl = _drift.BuildCompareUrl(Url ?? string.Empty);
        if (_drift.Kind == DriftKind.Ahead)
        {
            <div class="drift-banner drift-ahead" role="status">
                <span>
                    <strong>+@_drift.CommitsAhead commit@(_drift.CommitsAhead == 1 ? "" : "s")</strong>
                    landed since this review ran at <code>@ShortSha(_run.HeadSha)</code>.
                    Findings may not reflect the latest code.
                </span>
                @if (compareUrl is not null)
                {
                    <a href="@compareUrl" target="_blank" rel="noopener">See what changed</a>
                }
            </div>
        }
        else
        {
            <div class="drift-banner drift-forcepush" role="alert">
                <span>
                    ⚠ <strong>Force-push</strong> since this review ran at <code>@ShortSha(_run.HeadSha)</code>.
                    Comments may anchor to lines that no longer exist.
                </span>
                @if (compareUrl is not null)
                {
                    <a href="@compareUrl" target="_blank" rel="noopener">See what changed</a>
                }
            </div>
        }
    }

@if (_run is null)
{
    <p class="empty">No active review run for this PR. Launch one from the inbox first.</p>
}
else if (_run.Findings is null)
{
    <p class="empty">Review in progress · waiting for <code>findings.yaml</code> in @_run.RunDirectory</p>
}
else if (_run.Findings.Findings.Count == 0)
{
    <div class="clean-callout" role="status">
        <span class="clean-pill clean-pill-lg">✓ clean</span>
        <span>@CleanVerdict.BuildTooltip(_run.Findings, DateTimeOffset.UtcNow)</span>
    </div>
}
else
{
    var conv = ConvergenceVerdict.Compute(_run.Findings);
    @if (conv.State != ConvergenceState.Hidden)
    {
        <div class="convergence-callout convergence-callout-@conv.CssClass" role="status">
            <span class="convergence-pill-lg @conv.CssClass">@conv.Glyph</span>
            <span>@conv.Tooltip</span>
        </div>
    }

    <div class="severity-filters">
        <span class="muted">Filter:</span>
        <label><input type="checkbox" @bind="_showCritical" /> <span class="sev-critical">critical</span></label>
        <label><input type="checkbox" @bind="_showHigh" /> <span class="sev-high">high</span></label>
        <label><input type="checkbox" @bind="_showMedium" /> <span class="sev-medium">medium</span></label>
        <label><input type="checkbox" @bind="_showLow" /> <span class="sev-low">low</span></label>
    </div>

    <table class="findings-table">
        <thead>
            <tr>
                <th></th>
                <th>Sev</th>
                <th>File · line</th>
                <th>Title</th>
                <th>Anchor</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in VisibleFindings())
            {
                var fid = f.Id;
                <tr>
                    <td><input type="checkbox"
                               checked="@_selected.Contains(fid)"
                               @onchange="@(e => ToggleSelected(fid, (bool)e.Value!))" /></td>
                    <td><span class="@SevClass(f.Severity)">@f.Severity.ToString().ToLowerInvariant()</span></td>
                    <td><code>@f.File:@(f.Line?.ToString() ?? "?")</code></td>
                    <td>
                        @f.Title
                        @if (HasOverride(fid))
                        {
                            <span class="edit-badge" title="Body has been edited locally; original is in findings.yaml">edited</span>
                        }
                    </td>
                    <td class="muted">@(f.DiffAnchorable ? "inline" : "body-only")</td>
                </tr>
                <tr class="preview-row">
                    <td></td>
                    <td colspan="4">
                        <details>
                            <summary class="muted">Preview / edit comment</summary>
                            <div class="draft-block">
                                <div class="draft-toolbar">
                                    <span class="muted">Body (editable; blur to save)</span>
                                    @if (HasOverride(fid))
                                    {
                                        <button type="button" class="link-like"
                                                @onclick="@(() => OnResetDraft(fid))"
                                                title="Drop the edit and restore the body the agent wrote.">
                                            Reset to original
                                        </button>
                                    }
                                </div>
                                <textarea class="comment-draft"
                                          rows="8"
                                          spellcheck="false"
                                          value="@DraftFor(fid, f.Body ?? string.Empty)"
                                          @onchange="@(e => OnDraftCommit(fid, f.Body ?? string.Empty, e.Value as string))"></textarea>
                            </div>
                            <details class="rendered-preview">
                                <summary class="muted">Rendered comment (what gets posted)</summary>
                                <pre class="comment-preview">@PublishHelpers.ComposeInlineCommentBody(ToPostable(f))</pre>
                            </details>
                        </details>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <details class="review-body-preview">
        <summary class="muted">Preview review body (@SelectedCount() selected)</summary>
        <pre class="comment-preview">@BuildReviewBodyPreview()</pre>
    </details>

    <p class="accountability-note" role="note">
        ⚠ These are <strong>your</strong> review comments. AI assistance doesn't
        transfer accountability — read each finding before you publish. The
        review is posted under the identity bound to this PR (shown as
        <em>Identity used</em> after posting).
    </p>

    <div class="post-row">
        <label><input type="checkbox" @bind="_dryRun" /> <strong>Dry run</strong> (recommended; no network)</label>
        @if (IsGitHubUrl)
        {
            <label class="review-event">
                Verdict:
                <select @bind="_reviewEvent" disabled="@_posting">
                    <option value="@ReviewEvent.Comment">Comment</option>
                    <option value="@ReviewEvent.Approve">Approve</option>
                    <option value="@ReviewEvent.RequestChanges">Request changes</option>
                </select>
            </label>
        }
        <button class="review" disabled="@PostDisabled"
                @onclick="OnPostSelected">
            @PostButtonLabel
        </button>
    </div>
}

@if (_result is not null)
{
    <div class="@ResultClass(_result)">
        <h3>@(_result.Posted ? "Posted" : (_dryRun ? "Dry-run plan" : "Failed"))</h3>
        <ul>
            <li>Inline comments: <strong>@_result.InlineCount</strong></li>
            <li>Body-only entries: <strong>@_result.BodyOnlyCount</strong></li>
            <li>Skipped (already posted): <strong>@_result.SkippedAsAlreadyPosted</strong></li>
            @if (!string.IsNullOrEmpty(_result.PlatformReviewId))
            {
                <li>Platform review id: <code>@_result.PlatformReviewId</code></li>
            }
            @if (!string.IsNullOrEmpty(_result.ReviewUrl))
            {
                <li>Review URL: <a href="@_result.ReviewUrl" target="_blank" rel="noopener">@_result.ReviewUrl</a></li>
            }
            <li>Identity used: <code>@_result.IdentityUsed</code></li>
            @if (_result.HeadChanged)
            {
                <li>⚠ HEAD changed since brief — posted against @_result.HeadShaAtPost</li>
            }
        </ul>
        @if (_result.Warnings.Count > 0)
        {
            <details>
                <summary>Warnings (@_result.Warnings.Count)</summary>
                <ul>
                    @foreach (var w in _result.Warnings) { <li>@w</li> }
                </ul>
            </details>
        }
        @if (_result.Errors.Count > 0)
        {
            <details open>
                <summary>Errors (@_result.Errors.Count)</summary>
                <ul>
                    @foreach (var e in _result.Errors) { <li>@e</li> }
                </ul>
            </details>
        }
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "url")]
    public string? Url { get; set; }

    [SupplyParameterFromQuery(Name = "show")]
    public string? Show { get; set; }

    private ReviewRun? _run;
    private DriftInfo? _drift;
    private HashSet<string> _selected = new();
    private bool _showCritical = true;
    private bool _showHigh = true;
    private bool _showMedium = false;
    private bool _showLow = false;
    private bool _dryRun = true;
    private ReviewEvent _reviewEvent = ReviewEvent.Comment;
    private bool _posting;
    private PublishResult? _result;
    private InboxRow? _inboxRow;
    private bool _actionBusy;
    private string? _actionMessage;

    protected override void OnInitialized()
    {
        Runs.Changed += OnRunsChanged;
        State.Changed += OnInboxStateChanged;
        ApplyShowOverride();
        RefreshRun();
        RefreshInboxRow();
        _ = RefreshDriftAsync();
    }

    protected override void OnParametersSet()
    {
        ApplyShowOverride();
        RefreshRun();
        RefreshInboxRow();
        _ = RefreshDriftAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Stash this PR's URL so when the user returns to the inbox (via
        // "← back" or "Mark done & back"), the inbox can scroll to and pulse
        // exactly this row. See wwwroot/js/last-visited.js.
        if (!string.IsNullOrWhiteSpace(Url))
        {
            try { await Js.InvokeVoidAsync("prInboxLastVisited.mark", Url); }
            catch (Exception ex) { Log.LogDebug(ex, "mark last-visited failed"); }
        }
    }

    private void OnInboxStateChanged()
    {
        RefreshInboxRow();
        InvokeAsync(StateHasChanged);
    }

    private void RefreshInboxRow()
    {
        if (string.IsNullOrWhiteSpace(Url)) { _inboxRow = null; return; }
        _inboxRow = State.CurrentRows.FirstOrDefault(
            r => string.Equals(r.Url, Url, StringComparison.OrdinalIgnoreCase));
    }

    private async Task OnDoneAndBackAsync()
    {
        if (string.IsNullOrWhiteSpace(Url) || _actionBusy) return;
        _actionBusy = true;
        try
        {
            // Anchor "done" at the SHA we have in hand -- prefer the live
            // snapshot head, then the SHA the active review ran at, then a
            // sentinel. Mirrors OnToggleDoneAsync in Inbox.razor.
            var row = _inboxRow;
            var sha = row?.CurrentHeadSha
                      ?? row?.LastReviewedHeadSha
                      ?? _run?.HeadSha
                      ?? "unknown";
            var when = DateTimeOffset.UtcNow;
            await PrRepo.MarkDoneAsync(Url, sha, when, CancellationToken.None);
            if (row is not null)
            {
                State.Upsert(row with { MarkedDoneHeadSha = sha, MarkedDoneAt = when });
            }
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Mark done & back for {Url} failed", Url);
            _actionMessage = $"Could not mark done: {ex.Message}";
            _actionBusy = false;
            StateHasChanged();
        }
    }

    private async Task OnToggleFlagAsync()
    {
        if (string.IsNullOrWhiteSpace(Url) || _actionBusy) return;
        _actionBusy = true;
        try
        {
            var row = _inboxRow;
            if (row?.IsFlagged == true)
            {
                await PrRepo.UnflagAsync(Url, CancellationToken.None);
                State.Upsert(row with { FlaggedAt = null });
            }
            else
            {
                var when = DateTimeOffset.UtcNow;
                await PrRepo.FlagAsync(Url, when, CancellationToken.None);
                if (row is not null)
                {
                    State.Upsert(row with { FlaggedAt = when });
                }
            }
            RefreshInboxRow();
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Toggle flag for {Url} failed", Url);
            _actionMessage = $"Could not update flag: {ex.Message}";
        }
        finally
        {
            _actionBusy = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Force-enable any severity filter named in <c>?show=</c>. So clicking
    /// an L badge in the inbox doesn't land you on a page where the Low
    /// filter is unchecked and the finding you came for is invisible.
    /// Accepts any combination of C/H/M/L (case-insensitive).
    /// </summary>
    private void ApplyShowOverride()
    {
        if (string.IsNullOrEmpty(Show)) return;
        foreach (var ch in Show)
        {
            switch (char.ToUpperInvariant(ch))
            {
                case 'C': _showCritical = true; break;
                case 'H': _showHigh = true; break;
                case 'M': _showMedium = true; break;
                case 'L': _showLow = true; break;
            }
        }
    }

    private void OnRunsChanged()
    {
        RefreshRun();
        _ = RefreshDriftAsync();
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Fetch the most recent snapshot for this PR and compare it against
    /// the HEAD that the active review was authored at. Renders the drift
    /// banner when current HEAD has moved (ahead) or the branch was
    /// force-pushed since the run. Silently no-ops on lookup failures.
    /// </summary>
    private async Task RefreshDriftAsync()
    {
        try
        {
            if (_run is null || string.IsNullOrEmpty(Url))
            {
                _drift = null;
                return;
            }
            var identity = new PrIdentity(Url, string.Empty);
            var snap = await SnapRepo.GetLatestAsync(identity, CancellationToken.None);
            if (snap is null)
            {
                _drift = null;
                return;
            }
            // The anchor here is the HEAD the active review ran at,
            // not the row's persisted LastReviewRunHeadSha, because the
            // user is editing THIS review and wants to know if it has gone
            // stale.
            _drift = DriftInfo.Compute(_run.HeadSha, snap);
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "Drift refresh failed for {Url}", Url);
            _drift = null;
        }
        await InvokeAsync(StateHasChanged);
    }

    private static string ShortSha(string? sha)
    {
        if (string.IsNullOrEmpty(sha)) return "?";
        return sha.Length >= 7 ? sha[..7] : sha;
    }

    private void RefreshRun()
    {
        if (string.IsNullOrEmpty(Url)) { _run = null; return; }
        Runs.Snapshot().TryGetValue(Url, out _run);
        // Default: select all currently-visible findings.
        if (_run?.Findings is not null && _selected.Count == 0)
        {
            foreach (var f in VisibleFindings())
            {
                if (!string.IsNullOrEmpty(f.Id)) _selected.Add(f.Id);
            }
        }
    }

    private IEnumerable<Finding> VisibleFindings()
    {
        if (_run?.Findings is null) return Array.Empty<Finding>();
        return _run.Findings.Findings.Where(f => f.Severity switch
        {
            FindingSeverity.Critical => _showCritical,
            FindingSeverity.High => _showHigh,
            FindingSeverity.Medium => _showMedium,
            FindingSeverity.Low => _showLow,
            _ => true,
        });
    }

    private void ToggleSelected(string id, bool isChecked)
    {
        if (string.IsNullOrEmpty(id)) return;
        if (isChecked) _selected.Add(id); else _selected.Remove(id);
    }

    private async Task OnPostSelected()
    {
        if (_run?.Findings is null || string.IsNullOrEmpty(Url)) return;
        var picks = _run.Findings.Findings.Where(f => _selected.Contains(f.Id)).ToList();
        // For a plain Comment review, posting nothing is meaningless; for
        // an Approve / Request-changes vote, the body header alone is fine.
        if (picks.Count == 0 && _reviewEvent == ReviewEvent.Comment) return;

        if (!_dryRun)
        {
            var verb = _reviewEvent switch
            {
                ReviewEvent.Approve => "Approve",
                ReviewEvent.RequestChanges => "Request changes on",
                _ => "Post",
            };
            var suffix = picks.Count == 0
                ? $"{verb} {Url}? You are accountable for this AI-assisted review. This cannot be undone."
                : $"{verb} {Url} with {picks.Count} finding(s)? You are accountable for these AI-assisted comments. This cannot be undone.";
            var ok = await Js.InvokeAsync<bool>("confirm", suffix);
            if (!ok) return;
        }

        _posting = true;
        _result = null;
        StateHasChanged();
        try
        {
            var publishRequest = new PublishRequest(
                PrUrl: Url,
                RunId: _run.RunId,
                HeadShaAtAuthoring: _run.HeadSha,
                ReviewBodyHeader: BuildReviewBodyHeader(picks),
                Findings: picks.Select(ToPostable).ToArray(),
                DryRun: _dryRun,
                ValidateRemoteState: !_dryRun,
                Event: _reviewEvent);

            _result = await Orchestrator.PublishAsync(publishRequest, CancellationToken.None);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "PublishAsync threw");
            _result = PublishResult.Failure("unknown", ex.Message);
        }
        finally
        {
            _posting = false;
            StateHasChanged();
        }
    }

    private int SelectedCount() => _selected.Count;

    private string BuildReviewBodyPreview()
    {
        if (_run?.Findings is null) return string.Empty;
        var picks = _run.Findings.Findings.Where(f => _selected.Contains(f.Id)).ToList();
        if (picks.Count == 0) return "(select at least one finding to preview the review body)";
        var nonAnchorable = picks.Where(p => !p.DiffAnchorable).Select(ToPostable).ToArray();
        return PublishHelpers.ComposeReviewBody(
            header: BuildReviewBodyHeader(picks),
            nonAnchorable: nonAnchorable,
            headSha: _run.HeadSha);
    }

    private string BuildReviewBodyHeader(IReadOnlyList<Finding> picks)
    {
        var c = picks.Count(p => p.Severity == FindingSeverity.Critical);
        var h = picks.Count(p => p.Severity == FindingSeverity.High);
        var m = picks.Count(p => p.Severity == FindingSeverity.Medium);
        var l = picks.Count(p => p.Severity == FindingSeverity.Low);
        return $"Findings: {picks.Count} ({c} critical, {h} high, {m} medium, {l} low).";
    }

    /// <summary>
    /// True when the user has saved a body edit for this finding.
    /// </summary>
    private bool HasOverride(string fid)
        => !string.IsNullOrEmpty(fid)
           && _run?.BodyOverrides.ContainsKey(fid) == true;

    /// <summary>
    /// The text the textarea should currently show: override if any,
    /// else the parsed body from findings.yaml.
    /// </summary>
    private string DraftFor(string fid, string original)
    {
        if (_run is not null
            && !string.IsNullOrEmpty(fid)
            && _run.BodyOverrides.TryGetValue(fid, out var edited))
        {
            return edited;
        }
        return original;
    }

    /// <summary>
    /// Commit a textarea blur: if the new value matches the original
    /// (after line-ending normalisation) or is empty/whitespace, clear
    /// the override -- both mean "go back to the agent's prose, don't
    /// post a blank body". Otherwise save the override.
    /// </summary>
    private void OnDraftCommit(string fid, string original, string? newValue)
    {
        if (string.IsNullOrEmpty(Url) || string.IsNullOrEmpty(fid)) return;
        var draft = newValue ?? string.Empty;
        var normDraft    = NormalizeLineEndings(draft);
        var normOriginal = NormalizeLineEndings(original);
        if (string.IsNullOrWhiteSpace(normDraft) || normDraft == normOriginal)
        {
            Runs.ClearBodyOverride(Url, fid);
        }
        else
        {
            Runs.SetBodyOverride(Url, fid, draft);
        }
    }

    private void OnResetDraft(string fid)
    {
        if (string.IsNullOrEmpty(Url) || string.IsNullOrEmpty(fid)) return;
        Runs.ClearBodyOverride(Url, fid);
    }

    private static string NormalizeLineEndings(string s)
        => string.IsNullOrEmpty(s) ? string.Empty : s.Replace("\r\n", "\n").Replace("\r", "\n");

    /// <summary>
    /// Open findings.yaml in the OS default editor so the user can do
    /// bulk edits beyond the body-only inline path (e.g. drop a finding,
    /// retitle, fix severity, tweak the suggested-inline block).
    /// </summary>
    private void OnOpenFindingsYaml()
    {
        if (_run is null) return;
        var path = Path.Combine(_run.RunDirectory, "findings.yaml");
        if (!File.Exists(path)) return;
        try
        {
            System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo
            {
                FileName = path,
                UseShellExecute = true,
            });
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "Failed to open findings.yaml at {Path}", path);
        }
    }

    private FindingToPost ToPostable(Finding f) => new(
        Id: f.Id,
        Severity: f.Severity,
        Confidence: f.Confidence,
        FoundBy: f.FoundBy,
        File: f.File,
        Line: f.Line ?? 0,
        LineEnd: f.LineEnd,
        DiffAnchorable: f.DiffAnchorable,
        Title: f.Title,
        Body: DraftFor(f.Id, f.Body ?? string.Empty),
        SuggestedInline: f.SuggestedInline);

    /// <summary>True for GitHub.com / GHE URLs; false for ADO (which has
    /// no Approve/Request-changes verb wired through this publisher).</summary>
    private bool IsGitHubUrl =>
        !string.IsNullOrEmpty(Url) &&
        !Url.Contains("dev.azure.com", StringComparison.OrdinalIgnoreCase) &&
        !Url.Contains("visualstudio.com", StringComparison.OrdinalIgnoreCase);

    /// <summary>
    /// Post button is disabled when posting, OR when a plain Comment review
    /// would have no comments. Approve / Request-changes votes are allowed
    /// with no selected findings (the body header carries the verdict).
    /// </summary>
    private bool PostDisabled =>
        _posting || (_reviewEvent == ReviewEvent.Comment && _selected.Count == 0);

    private string PostButtonLabel
    {
        get
        {
            if (_posting) return "Posting...";
            var verb = _reviewEvent switch
            {
                ReviewEvent.Approve => "approve",
                ReviewEvent.RequestChanges => "request changes",
                _ => null,
            };
            var n = _selected.Count;
            if (_dryRun)
            {
                return verb is null
                    ? $"Plan {n} (dry-run)"
                    : $"Plan {verb} (dry-run, {n} finding{(n == 1 ? "" : "s")})";
            }
            return verb is null
                ? $"Post {n} live"
                : $"Post {verb} live ({n} finding{(n == 1 ? "" : "s")})";
        }
    }

    private static string SevClass(FindingSeverity s) => s switch
    {
        FindingSeverity.Critical => "sev-critical",
        FindingSeverity.High => "sev-high",
        FindingSeverity.Medium => "sev-medium",
        FindingSeverity.Low => "sev-low",
        _ => "muted",
    };

    private string ResultClass(PublishResult r) =>
        r.Errors.Count > 0 ? "post-result post-result-error" :
        r.Posted ? "post-result post-result-ok" :
        "post-result post-result-dry";

    public void Dispose()
    {
        Runs.Changed -= OnRunsChanged;
        State.Changed -= OnInboxStateChanged;
    }
}
