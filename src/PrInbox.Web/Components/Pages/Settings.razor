    private async Task SavePathFiltersAsync()
    {
        await WrapAsync(async () =>
        {
            var map = ParsePathFilters(_pathFiltersText);
            await ConfigSvc.SetRepoPathFiltersAsync(map);
            var repoCount = map.Count;
            var globCount = map.Values.Sum(v => v.Count);
            SetMessage($"Saved path filters for {repoCount} repo(s) ({globCount} folder pattern(s)).");
        });
    }

    /// <summary>
    /// Parse the "owner/repo: glob1, glob2" textarea into a repo -> patterns
    /// map. Lines without a colon, or with no usable patterns, are dropped.
    /// Only the first colon splits repo from patterns so paths can't contain
    /// one anyway, but we stay defensive.
    /// </summary>
    private static Dictionary<string, IReadOnlyList<string>> ParsePathFilters(string? text)
    {
        var map = new Dictionary<string, IReadOnlyList<string>>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(text)) return map;

        foreach (var rawLine in text.Split('\n', StringSplitOptions.RemoveEmptyEntries))
        {
            var line = rawLine.Trim();
            if (line.Length == 0) continue;

            var colon = line.IndexOf(':');
            if (colon <= 0) continue; // no repo key, or empty key

            var repo = line[..colon].Trim();
            if (repo.Length == 0) continue;

            var globs = line[(colon + 1)..]
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(g => g.Trim())
                .Where(g => g.Length > 0)
                .ToList();
            if (globs.Count == 0) continue;

            map[repo] = globs;
        }
        return map;
    }

    private Task OnAutoSendChanged(bool value)
    {
        _autoSend = value;
        return PersistLauncherFlagsAsync($"Auto-send brief {(value ? "ON" : "OFF")}.");
    }

    private Task OnYoloChanged(bool value)
    {
        _yolo = value;
        return PersistLauncherFlagsAsync($"Yolo {(value ? "ON" : "OFF")}.");
    }

    // Value bound to the native colour picker, which only accepts a
    // 6-digit hex. Falls back to the app accent when the configured
    // value is blank (disabled) or a 3-digit hex the picker can't show.
    private string TabColorPickerValue =>
        ReviewLauncherSettings.NormalizeTabColor(_tabColor) is { Length: 7 } hex
            ? hex
            : "#5da4ff";

    private async Task OnTabColorChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString()?.Trim() ?? string.Empty;
        if (raw.Length == 0)
        {
            _tabColor = string.Empty;
            await PersistTabColorAsync(string.Empty, "Review tab colour disabled.");
            return;
        }

        var normalized = ReviewLauncherSettings.NormalizeTabColor(raw);
        if (normalized is null)
        {
            _tabColor = raw;
            SetMessage("Enter a hex colour like #5da4ff, or leave blank to disable.", isError: true);
            return;
        }

        _tabColor = normalized;
        await PersistTabColorAsync(normalized, $"Review tab colour set to {normalized}.");
    }

    private Task PersistTabColorAsync(string tabColor, string okMessage) =>
        WrapAsync(async () =>
        {
            await ConfigSvc.SetReviewLauncherTabColorAsync(tabColor);
            SetMessage(okMessage);
        });

    private async Task PersistLauncherFlagsAsync(string okMessage)
    {
        await WrapAsync(async () =>
        {
            await ConfigSvc.SetReviewLauncherFlagsAsync(_autoSend, _yolo);
            SetMessage(okMessage);
        });
    }

    private async Task RunDoctorAsync()
    {
        if (_doctorBusy) return;
        _doctorBusy = true;
        _busy = true;
        try
        {
            _doctorReport = await Doctor.RunAsync();
            SetMessage(_doctorReport.Base.AllOk ? "Doctor: all sources healthy." : "Doctor: one or more sources failed.",
                       isError: !_doctorReport.Base.AllOk);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Doctor run failed.");
            SetMessage($"Doctor failed: {ex.Message}", isError: true);
        }
        finally
        {
            _doctorBusy = false;
            _busy = false;
        }
    }

    private async Task WrapAsync(Func<Task> action)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            await action();
            await ReloadAsync();
            _isFirstRun = false;
            // Source/config mutated — let the Inbox kick an out-of-band
            // sync on next arrival instead of waiting up to one full
            // background interval. Single-shot; consumed by Inbox.razor.
            Sync.NoteConfigChanged();
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Settings action failed.");
            SetMessage($"Error: {ex.Message}", isError: true);
        }
        finally
        {
            _busy = false;
        }
    }

    private void SetMessage(string text, bool isError = false)
    {
        _lastMessage = text;
        _lastWasError = isError;
    }
}
