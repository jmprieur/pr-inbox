    private async Task RunAdvisoryActionAsync(DoctorAdvisoryAction action)
    {
        if (_busy) return;
        switch (action.Kind)
        {
            case DoctorAdvisoryActionKind.BindToIdentity:
                _bindingSourceId = action.SourceId;
                try
                {
                    await WrapAsync(async () =>
                    {
                        var result = await ConfigSvc.BindGitHubSourceToIdentityAsync(
                            action.SourceId, action.TargetIdentity);
                        var msg = result switch
                        {
                            BindIdentityResult.Migrated =>
                                $"Bound `{action.SourceId}` to `{action.TargetIdentity}`.",
                            BindIdentityResult.RemovedDuplicate =>
                                $"Removed `{action.SourceId}` (explicit source for `{action.TargetIdentity}` already exists).",
                            BindIdentityResult.NotFound =>
                                $"Source `{action.SourceId}` no longer exists — refresh and try again.",
                            BindIdentityResult.NotEligible =>
                                $"Source `{action.SourceId}` is not a default-identity GitHub source; cannot bind.",
                            _ => $"Unexpected bind result: {result}",
                        };
                        var isError = result is BindIdentityResult.NotFound or BindIdentityResult.NotEligible;
                        SetMessage(msg, isError);
                    });
                    // Re-run Doctor so the now-stale advisory disappears.
                    if (!_lastWasError)
                    {
                        await RunDoctorAsync();
                    }
                }
                finally
                {
                    _bindingSourceId = null;
                }
                break;

            case DoctorAdvisoryActionKind.RetrySync:
                // Kicks the background sync immediately (out-of-band).
                // The sync loop reloads config each cycle, so we don't
                // need to mutate anything here — just nudge it.
                Sync.NoteConfigChanged();
                SetMessage($"Sync nudged for `{action.SourceId}` — the background loop will pick it up momentarily.");
                // Briefly delay then re-run Doctor so the user sees the
                // status update once the sync completes. We don't await
                // sync completion (no such hook today); ~3s is enough
                // for a typical single-source fetch.
                await Task.Delay(TimeSpan.FromSeconds(3));
                await RunDoctorAsync();
                break;
        }
    }

