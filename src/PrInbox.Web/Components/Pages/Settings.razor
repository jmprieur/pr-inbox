@page "/settings"
@rendermode InteractiveServer
@using PrInbox.Core.Config
@using PrInbox.Core.Credentials
@inject IConfigService ConfigSvc
@inject IGitHubAuthDiscovery GhAuthDiscovery
@inject DoctorService Doctor
@inject InboxSyncHostedService Sync
@inject ILogger<Settings> Log

<h1>Settings</h1>

@if (_cfg is null)
{
    <p class="empty">Loading…</p>
}
else
{
    @if (_isFirstRun)
    {
        <div class="settings-banner first-run">
            <strong>First run.</strong> Add at least one source below to start seeing PRs.
        </div>
    }
    else if (!string.IsNullOrEmpty(_lastMessage))
    {
        <div class="settings-banner @( _lastWasError ? "error" : "ok")">@_lastMessage</div>
    }

    <p class="muted">Config file: <code>@ConfigSvc.ConfigPath</code></p>

    <section class="settings-section">
        <h2>Sources</h2>
        @if (_cfg.Sources.Count == 0)
        {
            <p class="empty">No sources yet.</p>
        }
        else
        {
            <table class="settings-table">
                <thead>
                    <tr><th>ID</th><th>Kind</th><th>Host</th><th>Identity</th><th>Enabled</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var s in _cfg.Sources)
                    {
                        <tr>
                            <td><code>@s.Id</code></td>
                            <td>@KindLabel(s.Kind)</td>
                            <td>@(s.Host ?? "—")</td>
                            <td>@s.Identity</td>
                            <td>@(s.Enabled ? "yes" : "no")</td>
                            <td>
                                <button class="link-button danger"
                                        @onclick="@(() => RemoveSourceAsync(s.Id))"
                                        disabled="@_busy">Remove</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="settings-actions">
            <button @onclick="StartAddGitHubComAsync" disabled="@_busy">+ Add GitHub.com</button>
            <button @onclick="@(() => _showGheForm = !_showGheForm)" disabled="@_busy">+ Add GitHub Enterprise…</button>
        </div>

        @if (_ghComDiscovering)
        {
            <div class="settings-inline-form">
                <p class="muted">Discovering GitHub logins via <code>gh auth status</code>…</p>
            </div>
        }
        else if (_ghComPicker)
        {
            <div class="settings-inline-form">
                @if (_ghComUnbound.Count == 0)
                {
                    <p class="muted">
                        No GitHub logins detected via <code>gh</code>
                        @if (_ghComAlreadyBound.Count > 0)
                        {
                            <text>(<strong>@_ghComAlreadyBound.Count</strong> already bound below)</text>
                        }
                        . You can still add <code>github.com</code> with the default identity — it will use whichever <code>gh</code> account is active when the next sync runs, or fail at sync time if <code>gh</code> isn't installed.
                    </p>
                }
                else
                {
                    <p class="muted">
                        Pick a GitHub login to bind to a new <code>github.com</code> source.
                        Each identity here will sync independently — useful when you have separate personal and enterprise accounts (e.g. <code>jmprieur</code> + <code>jmprieur_microsoft</code>).
                    </p>
                    @if (_isFirstRun && _ghComUnbound.Count > 1)
                    {
                        <div class="settings-inline-form-actions">
                            <button class="settings-identity-button settings-identity-add-all"
                                    @onclick="AddAllGitHubIdentitiesAsync"
                                    disabled="@_busy">
                                <strong>+ Add all @_ghComUnbound.Count GitHub identities</strong>
                                <span class="muted">recommended — you can remove any later</span>
                            </button>
                        </div>
                    }
                    <div class="settings-identity-list">
                        @foreach (var identity in _ghComUnbound)
                        {
                            var localId = identity;
                            <button class="settings-identity-button"
                                    @onclick="@(() => AddGitHubComWithIdentityAsync(localId))"
                                    disabled="@_busy">
                                <strong>@localId.Login</strong>
                                <span class="muted">
                                    @if (localId.IsActive) { <text>active · </text> }
                                    @(localId.IsEmu ? "EMU" : "public")
                                </span>
                            </button>
                        }
                    </div>
                }
                <div class="settings-inline-form-actions">
                    <button @onclick="AddGitHubComDefaultAsync" disabled="@_busy">
                        + Add with default identity
                    </button>
                    <button class="link-button" @onclick="CancelGhComPicker">Cancel</button>
                </div>
                @if (_ghComUnbound.Any(i => i.IsActive) && _cfg.Sources.Any(s => IsGitHubComDefaultSource(s)))
                {
                    <p class="settings-warning muted">
                        Heads up: you already have a <code>github.com</code> source bound to the default identity, and the <strong>active</strong>
                        <code>gh</code> account is shown above. If you add it explicitly here, both sources will fetch the same PRs from the same account. Consider removing the default-identity source after this.
                    </p>
                }
            </div>
        }

        @if (_showGheForm)
        {
            <div class="settings-inline-form">
                <label>Host
                    <input @bind="_gheHost" placeholder="github.contoso.com" />
                </label>
                <label>Custom id (optional)
                    <input @bind="_gheCustomId" placeholder="ghe.contoso" />
                </label>
                <div class="settings-inline-form-actions">
                    <button @onclick="AddGheAsync" disabled="@_busy">Add</button>
                    <button class="link-button" @onclick="CancelGheForm">Cancel</button>
                </div>
            </div>
        }
    </section>

    <section class="settings-section">
        <h2>Azure DevOps projects</h2>
        @if (_cfg.Ado.Projects.Count == 0)
        {
            <p class="empty">No ADO projects.</p>
        }
        else
        {
            <table class="settings-table">
                <thead>
                    <tr><th>Org</th><th>Project</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var p in _cfg.Ado.Projects)
                    {
                        <tr>
                            <td>@p.Org</td>
                            <td>@p.Project</td>
                            <td>
                                <button class="link-button danger"
                                        @onclick="@(() => RemoveAdoAsync(p.Org, p.Project))"
                                        disabled="@_busy">Remove</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <div class="settings-actions">
            <button @onclick="@(() => _showAdoForm = !_showAdoForm)" disabled="@_busy">+ Add ADO project…</button>
        </div>
        @if (_showAdoForm)
        {
            <div class="settings-inline-form">
                <label>Org   <input @bind="_adoOrg"     placeholder="mseng" /></label>
                <label>Project <input @bind="_adoProject" placeholder="Context" /></label>
                <div class="settings-inline-form-actions">
                    <button @onclick="AddAdoAsync" disabled="@_busy">Add</button>
                    <button class="link-button" @onclick="CancelAdoForm">Cancel</button>
                </div>
            </div>
        }
    </section>

    <section class="settings-section">
        <h2>Doctor</h2>
        <p class="muted">
            Per-source health: can we mint a token? Has the background sync actually run?
            Are we wasting work fetching the same PRs twice?
        </p>
        <div class="settings-actions">
            <button @onclick="RunDoctorAsync" disabled="@(_busy || _cfg.Sources.Count == 0)">
                @(_doctorBusy ? "Running…" : (_doctorReport is null ? "Run checks" : "Refresh"))
            </button>
            @if (_doctorReport is not null)
            {
                <span class="muted">
                    @(_doctorReport.Base.AllOk ? "All sources healthy." : "One or more sources failed.")
                </span>
            }
        </div>

        @if (_doctorReport is not null)
        {
            @foreach (var advisory in _doctorReport.Advisories)
            {
                <div class="settings-advisory @(advisory.Severity == DoctorAdvisorySeverity.Warning ? "warning" : "info")">
                    <strong>@advisory.Title</strong>
                    <p>@advisory.Detail</p>
                    <p class="settings-advisory-suggestion">@advisory.Suggestion</p>
                    @if (advisory.Actions is { Count: > 0 } actions)
                    {
                        <div class="settings-advisory-actions">
                            @foreach (var action in actions)
                            {
                                <button class="settings-advisory-fix"
                                        disabled="@_busy"
                                        @onclick="() => RunAdvisoryActionAsync(action)">
                                    @(_bindingSourceId == action.SourceId ? "Working…" : ("Fix: " + action.Label))
                                </button>
                            }
                        </div>
                    }
                </div>
            }

            <table class="settings-table doctor-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Kind</th>
                        <th>Identity</th>
                        <th>Auth</th>
                        <th>Last sync</th>
                        <th>Open PRs</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _doctorReport.Sources)
                    {
                        var b = r.Base;
                        <tr class="@(b.Ok ? "ok" : "fail")">
                            <td><code>@b.Id</code></td>
                            <td>@KindLabel(b.Kind)</td>
                            <td>
                                @if (b.Ok && b.Identity is not null)
                                {
                                    if (string.Equals(b.Identity, "default", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="muted">default</span>
                                    }
                                    else
                                    {
                                        <span>@b.Identity</span>
                                        @if (r.IsEmu == true) { <span class="identity-chip emu">EMU</span> }
                                        else if (r.IsEmu == false) { <span class="identity-chip public">public</span> }
                                        @if (r.IsActiveGhLogin) { <span class="identity-chip active">active</span> }
                                    }
                                }
                                else if (!b.Enabled)
                                {
                                    <span class="muted">disabled</span>
                                }
                                else
                                {
                                    <span class="muted">—</span>
                                }
                            </td>
                            <td>
                                @if (!b.Enabled) { <span class="muted">—</span> }
                                else if (b.Ok)   { <span class="status-ok">● ok</span> }
                                else
                                {
                                    <span class="status-fail">● failed</span>
                                    @if (b.Error is not null) { <div class="muted doctor-error">@b.Error</div> }
                                }
                            </td>
                            <td>
                                @if (r.LastSyncAt is null)
                                {
                                    <span class="muted">never</span>
                                }
                                else
                                {
                                    var statusClass = r.LastSyncStatus switch
                                    {
                                        SyncRunStatus.Ok => "status-ok",
                                        SyncRunStatus.Partial => "status-partial",
                                        SyncRunStatus.RateLimited => "status-partial",
                                        SyncRunStatus.Failed => "status-fail",
                                        _ => "muted",
                                    };
                                    <span class="@statusClass" title="@r.LastSyncAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")">
                                        @RelativeTime(r.LastSyncAt.Value)
                                    </span>
                                    @if (r.LastSyncStatus == SyncRunStatus.Failed && r.LastSyncError is not null)
                                    {
                                        <div class="muted doctor-error">@r.LastSyncError</div>
                                    }
                                }
                            </td>
                            <td>@r.OpenPrCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="settings-section">
        <h2>Ignored repos</h2>
        <p class="muted">One regex per line. PRs whose display repo (e.g. <code>1ES/Spmi</code>) matches one of these are hidden by default in the Inbox.</p>
        <textarea class="settings-textarea" rows="6" @bind="_ignoredReposText"></textarea>
        <div class="settings-actions">
            <button @onclick="SaveIgnoredReposAsync" disabled="@_busy">Save</button>
        </div>
    </section>

    <section class="settings-section">
        <h2>Monorepo path filters</h2>
        <p class="muted">
            For a monorepo, only show PRs that touch certain folders. One line per repo,
            in the form <code>owner/repo: folder1, folder2/**</code>. A PR is shown when it
            touches <em>any</em> listed folder (OR). Repos with no line here are unaffected.
        </p>
        <ul class="muted" style="margin-top:0">
            <li><code>src/ServiceA</code> — that folder and everything under it (a bare path matches its whole subtree).</li>
            <li><code>src/Shared/**</code> — end a pattern with <code>/**</code> to match everything inside a folder.</li>
            <li><code>src/*/api/**</code> — <code>*</code> matches a single folder name; <code>**</code> matches across folders.</li>
            <li>Out-of-scope PRs are hidden by default; the Inbox "Show out-of-scope" toggle reveals them.</li>
            <li>PRs not yet enriched, Azure DevOps PRs, and very large PRs are always shown (fail-open).</li>
        </ul>
        <textarea class="settings-textarea" rows="5" placeholder="contoso/monorepo: src/ServiceA, src/Shared/**" @bind="_pathFiltersText"></textarea>
        <div class="settings-actions">
            <button @onclick="SavePathFiltersAsync" disabled="@_busy">Save</button>
        </div>
    </section>

    <section class="settings-section">
        <h2>Review launcher</h2>
        <p class="muted">
            How the Review button drives the dual-model-review agent.
            Both flags take effect immediately on the <em>next</em> review you launch — running consoles are unaffected.
        </p>
        <div class="settings-toggle">
            <label>
                <input type="checkbox"
                       checked="@_autoSend"
                       @onchange="@(e => OnAutoSendChanged((bool)e.Value!))"
                       disabled="@_busy" />
                <strong>Auto-send brief</strong>
                <span class="muted">
                    On: launcher hands the brief to the agent via <code>-i</code> so the run starts hands-free.
                    Off: brief is copied to the clipboard and you paste it (Ctrl+V) yourself.
                </span>
            </label>
        </div>
        <div class="settings-toggle">
            <label>
                <input type="checkbox"
                       checked="@_yolo"
                       @onchange="@(e => OnYoloChanged((bool)e.Value!))"
                       disabled="@_busy" />
                <strong>Yolo</strong>
                <span class="muted">
                    Appends <code>--yolo</code> to copilot
                    (= <code>--allow-all-tools --allow-all-paths --allow-all-urls</code>):
                    every permission prompt is auto-approved.
                    Faster + truly unattended, but no per-action gates — use only when you trust the agent's plugin/agent.
                </span>
            </label>
        </div>
        <div class="settings-toggle">
            <label>
                <strong>Tab colour</strong>
                <span class="muted">
                    Colours the Windows Terminal tab for every review so it stands out from ordinary terminals.
                    Accepts a hex like <code>#5da4ff</code>; leave blank to disable.
                </span>
                <span style="display:inline-flex; align-items:center; gap:.5rem; margin-top:.35rem;">
                    <input type="color"
                           value="@TabColorPickerValue"
                           @onchange="OnTabColorChanged"
                           disabled="@_busy"
                           title="Pick a colour" />
                    <input type="text"
                           value="@_tabColor"
                           @onchange="OnTabColorChanged"
                           placeholder="#5da4ff"
                           disabled="@_busy"
                           style="width:8rem;" />
                </span>
            </label>
        </div>
    </section>

    <p class="muted">
        Some changes take effect immediately (ignored repos, next sync tick). Adding or removing a source updates publisher wiring only after the next app restart.
    </p>
}

@code {
    private PrInboxConfig? _cfg;
    private EnrichedDoctorReport? _doctorReport;
    private string _ignoredReposText = string.Empty;
    private string _pathFiltersText = string.Empty;
    private bool _autoSend = true;
    private bool _yolo;
    private string _tabColor = string.Empty;

    private bool _showGheForm;
    private string _gheHost = string.Empty;
    private string _gheCustomId = string.Empty;

    private bool _showAdoForm;
    private string _adoOrg = string.Empty;
    private string _adoProject = string.Empty;

    private bool _busy;
    private bool _doctorBusy;
    private bool _isFirstRun;
    private string? _lastMessage;
    private bool _lastWasError;
    // Source id currently being migrated via a Doctor advisory action.
    // Used to spin a per-button label while the bind round-trips.
    private string? _bindingSourceId;

    // GitHub.com add-flow state.
    // _ghComPicker: show the inline identity picker (true between
    // discovery completing and the user committing / cancelling).
    // _ghComDiscovering: spinner state while gh auth status runs.
    // _ghComUnbound: identities surfaced by discovery that aren't
    // already bound by any existing source. Empty list with the picker
    // open = the "no identities" branch.
    // _ghComAlreadyBound: identities found by discovery that ARE
    // already bound — shown as an informational hint only.
    private bool _ghComPicker;
    private bool _ghComDiscovering;
    private IReadOnlyList<GitHubAuthIdentity> _ghComUnbound = Array.Empty<GitHubAuthIdentity>();
    private IReadOnlyList<GitHubAuthIdentity> _ghComAlreadyBound = Array.Empty<GitHubAuthIdentity>();

    protected override async Task OnInitializedAsync()
    {
        _isFirstRun = !ConfigSvc.ConfigFileExists();
        await ReloadAsync();

        // First-run cooperation: pre-open the github.com identity picker
        // in 'Discovering…' state so the first paint already shows the
        // spinner. The actual `gh auth status` shell-out (up to 8s)
        // runs in OnAfterRenderAsync below so we don't block first
        // paint — without this, the page would appear frozen for
        // several seconds on every fresh start, making users wonder if
        // the app is hung.
        if (_isFirstRun)
        {
            _ghComPicker = true;
            _ghComDiscovering = true;
            _ghComUnbound = Array.Empty<GitHubAuthIdentity>();
            _ghComAlreadyBound = Array.Empty<GitHubAuthIdentity>();
        }
    }

    private bool _firstRunProbeStarted;
    private bool _doctorAutoRunStarted;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Phase 1: first-run gh identity probe (only when no config yet).
        if (_isFirstRun && !_firstRunProbeStarted)
        {
            _firstRunProbeStarted = true;
            await StartAddGitHubComAsync();
            StateHasChanged();
        }

        // Phase 2: auto-run Doctor when the user has at least one source
        // configured. Skipped on first run (no sources to check, and we
        // don't want to compete with the gh probe for CPU). Same
        // motivation as the gh probe: render placeholder synchronously,
        // shell out asynchronously, then repaint. _doctorAutoRunStarted
        // gates against SignalR-reconnect double-fires.
        if (!_isFirstRun && !_doctorAutoRunStarted && _cfg is not null && _cfg.Sources.Count > 0)
        {
            _doctorAutoRunStarted = true;
            await RunDoctorAsync();
            StateHasChanged();
        }
    }

    /// <summary>
    /// Render a DateTimeOffset as a short relative string ("3m ago",
    /// "2h ago", "yesterday", "5d ago"). Anything older than a week
    /// falls back to absolute date. Used in the Doctor "Last sync"
    /// column so the user can scan freshness at a glance without
    /// computing UTC offsets in their head.
    /// </summary>
    private static string RelativeTime(DateTimeOffset when)
    {
        var delta = DateTimeOffset.UtcNow - when;
        if (delta < TimeSpan.Zero) return "just now";
        if (delta.TotalSeconds < 60) return "just now";
        if (delta.TotalMinutes < 60) return $"{(int)delta.TotalMinutes}m ago";
        if (delta.TotalHours < 24) return $"{(int)delta.TotalHours}h ago";
        if (delta.TotalDays < 2) return "yesterday";
        if (delta.TotalDays < 7) return $"{(int)delta.TotalDays}d ago";
        return when.ToLocalTime().ToString("yyyy-MM-dd");
    }

    private async Task ReloadAsync()
    {
        _cfg = await ConfigSvc.GetAsync();
        _ignoredReposText = string.Join("\n", _cfg.IgnoredRepos);
        _pathFiltersText = FormatPathFilters(_cfg.RepoPathFilters);
        _autoSend = _cfg.ReviewLauncher.AutoSend;
        _yolo = _cfg.ReviewLauncher.Yolo;
        _tabColor = _cfg.ReviewLauncher.TabColor;
    }

    private static string FormatPathFilters(IReadOnlyDictionary<string, List<string>> filters)
        => string.Join("\n", filters
            .Where(kv => kv.Value is { Count: > 0 })
            .Select(kv => $"{kv.Key}: {string.Join(", ", kv.Value)}"));

    private static string KindLabel(SourceConfigKind kind) => kind switch
    {
        SourceConfigKind.GitHub => "github",
        SourceConfigKind.GitHubEnterprise => "github-enterprise",
        SourceConfigKind.AzureDevOps => "azure-devops",
        _ => kind.ToString(),
    };

    private async Task StartAddGitHubComAsync()
    {
        // Reset picker state and kick off lazy discovery. The picker
        // section is rendered based on _ghComDiscovering / _ghComPicker
        // so the UI flips immediately to "Discovering…" before the
        // shell-out finishes.
        if (_busy) return;
        _ghComPicker = true;
        _ghComDiscovering = true;
        _ghComUnbound = Array.Empty<GitHubAuthIdentity>();
        _ghComAlreadyBound = Array.Empty<GitHubAuthIdentity>();
        StateHasChanged();

        try
        {
            var discovered = await GhAuthDiscovery.ListIdentitiesAsync("github.com");
            var cfg = _cfg ?? await ConfigSvc.GetAsync();
            // An identity is "already bound" if any github.com source's
            // Identity field equals the login (case-insensitive). The
            // default-identity source (Identity == "default") doesn't
            // bind a login, so it doesn't subtract anything from the
            // unbound list.
            var bound = cfg.Sources
                .Where(s => s.Kind == SourceConfigKind.GitHub
                            && string.Equals(s.Host, "github.com", StringComparison.OrdinalIgnoreCase))
                .Select(s => s.Identity)
                .Where(id => !string.Equals(id, "default", StringComparison.OrdinalIgnoreCase))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            _ghComUnbound = discovered.Where(i => !bound.Contains(i.Login)).ToList();
            _ghComAlreadyBound = discovered.Where(i => bound.Contains(i.Login)).ToList();
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "gh identity discovery failed for github.com; user can still add with default identity.");
            _ghComUnbound = Array.Empty<GitHubAuthIdentity>();
            _ghComAlreadyBound = Array.Empty<GitHubAuthIdentity>();
        }
        finally
        {
            _ghComDiscovering = false;
        }
    }

    private async Task AddGitHubComWithIdentityAsync(GitHubAuthIdentity identity)
    {
        await WrapAsync(async () =>
        {
            var added = await ConfigSvc.AddGitHubSourceWithIdentityAsync(
                SourceConfigKind.GitHub, "github.com", identity.Login);
            SetMessage(
                added
                    ? $"Added github.com source for {identity.Login}."
                    : $"A source for {identity.Login} already exists.",
                isError: !added);
            if (added) CancelGhComPicker();
        });
    }

    private async Task AddAllGitHubIdentitiesAsync()
    {
        // Bulk add path for the first-run cooperative case. Snapshots
        // the unbound list before any mutation so reload-driven changes
        // mid-loop don't skip an entry. Counts both successful adds and
        // pre-existing collisions so the banner is accurate even if the
        // user clicked "Add all" twice.
        var snapshot = _ghComUnbound.ToList();
        await WrapAsync(async () =>
        {
            var added = 0;
            var skipped = 0;
            foreach (var identity in snapshot)
            {
                var ok = await ConfigSvc.AddGitHubSourceWithIdentityAsync(
                    SourceConfigKind.GitHub, "github.com", identity.Login);
                if (ok) added++;
                else skipped++;
            }
            var msg = added == 1
                ? "Added 1 github.com source."
                : $"Added {added} github.com sources.";
            if (skipped > 0) msg += $" ({skipped} already existed.)";
            SetMessage(msg, isError: added == 0);
            if (added > 0) CancelGhComPicker();
        });
    }

    private async Task AddGitHubComDefaultAsync()
    {
        // Legacy escape hatch: add a default-identity source (uses
        // whichever gh account is active at sync time). Kept so users
        // without gh installed can still wire github.com.
        await WrapAsync(async () =>
        {
            var added = await ConfigSvc.AddGitHubSourceAsync(SourceConfigKind.GitHub, "github.com");
            SetMessage(
                added
                    ? "Added github.com (default identity)."
                    : "A default-identity github.com source already exists.",
                isError: !added);
            if (added) CancelGhComPicker();
        });
    }

    private void CancelGhComPicker()
    {
        _ghComPicker = false;
        _ghComDiscovering = false;
        _ghComUnbound = Array.Empty<GitHubAuthIdentity>();
        _ghComAlreadyBound = Array.Empty<GitHubAuthIdentity>();
    }

    private static bool IsGitHubComDefaultSource(SourceConfig s)
        => s.Kind == SourceConfigKind.GitHub
           && string.Equals(s.Host, "github.com", StringComparison.OrdinalIgnoreCase)
           && string.Equals(s.Identity, "default", StringComparison.OrdinalIgnoreCase);

    private async Task AddGheAsync()
    {
        var host = _gheHost?.Trim() ?? "";
        if (string.IsNullOrEmpty(host))
        {
            SetMessage("Host is required.", isError: true);
            return;
        }
        await WrapAsync(async () =>
        {
            var id = string.IsNullOrWhiteSpace(_gheCustomId) ? null : _gheCustomId.Trim();
            var added = await ConfigSvc.AddGitHubSourceAsync(SourceConfigKind.GitHubEnterprise, host, id);
            if (added)
            {
                SetMessage($"Added GitHub Enterprise source for {host}.");
                _showGheForm = false;
                _gheHost = string.Empty;
                _gheCustomId = string.Empty;
            }
            else
            {
                SetMessage($"A source with the same id already exists.", isError: true);
            }
        });
    }

    private void CancelGheForm()
    {
        _showGheForm = false;
        _gheHost = string.Empty;
        _gheCustomId = string.Empty;
    }

    private async Task AddAdoAsync()
    {
        var org = _adoOrg?.Trim() ?? "";
        var project = _adoProject?.Trim() ?? "";
        if (string.IsNullOrEmpty(org) || string.IsNullOrEmpty(project))
        {
            SetMessage("Org and project are required.", isError: true);
            return;
