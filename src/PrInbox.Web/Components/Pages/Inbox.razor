@page "/"
@rendermode InteractiveServer
@implements IDisposable
@using System.Text.Json
@using System.Text.RegularExpressions
@using PrInbox.Core.Config
@using PrInbox.Core.Credentials
@using PrInbox.Core.Models
@using PrInbox.Core.Storage
@inject InboxState State
@inject ReviewRunStore Runs
@inject IReviewLauncher Launcher
@inject InboxSyncHostedService Sync
@inject PullRequestRepository PrRepo
@inject UiPreferencesRepository Prefs
@inject PrInboxConfig Config
@inject IConfigService ConfigSvc
@inject ConsoleWindowRegistry Consoles
@inject NavigationManager Nav
@inject ILogger<Inbox> Log

<h1>Pull requests assigned to me</h1>

<div class="toolbar">
    <span class="muted">@RowCountLabel</span>
    <span class="muted">@LastSyncLabel</span>
    <button class="refresh" @onclick="OnRefreshAsync" disabled="@_refreshing">
        @(_refreshing ? "Refreshing..." : "Refresh")
    </button>

    <div class="source-chips" role="group" aria-label="Source filter">
        @foreach (var chip in SourceChips)
        {
            <label class="chip @(chip.Class) @(IsSourceEnabled(chip.Class) ? "on" : "off")">
                <input type="checkbox"
                       checked="@IsSourceEnabled(chip.Class)"
                       @onchange="@(e => OnSourceChipToggleAsync(chip.Class, (bool)e.Value!))" />
                @chip.Label
            </label>
        }
    </div>

    <div class="repo-filter">
        <button type="button"
                class="repo-pill @(_excludedRepos.Count > 0 ? "active" : "") @(_repoFilterOpen ? "open" : "")"
                @onclick="ToggleRepoFilterPopover"
                title="@RepoFilterTooltip">
            @RepoFilterPillLabel
            <span class="repo-pill-caret">▾</span>
        </button>
        @if (_repoFilterOpen)
        {
            <div class="repo-popover-backdrop" @onclick="CloseRepoFilterPopover"></div>
            <div class="repo-popover" role="dialog" aria-label="Per-repo filter">
                <input type="search"
                       class="repo-popover-search"
                       placeholder="Filter repos…"
                       @bind="_repoFilterSearch"
                       @bind:event="oninput" />
                @{
                    var repoItems = FilteredRepoListItems;
                    var canHideVisibleRepos = repoItems.Any(i => i.Count > 0 && !i.Excluded);
                }
                <div class="repo-popover-actions">
                    <button type="button"
                            class="link-like"
                            disabled="@(_excludedRepos.Count == 0)"
                            @onclick="OnShowAllReposAsync">Show all</button>
                    <button type="button"
                            class="link-like"
                            disabled="@(!canHideVisibleRepos)"
                            title="Hide every repo currently shown in this list."
                            @onclick="OnHideVisibleReposAsync">Hide visible</button>
                    <span class="muted">@RepoFilterStatusLine</span>
                </div>
                <div class="repo-popover-sort">
                    <span class="muted">Sort:</span>
                    <button type="button"
                            class="sort-btn @(_repoSortMode == InboxFilterSortMode.Count ? "active" : "")"
                            title="Sort by PR count, highest first."
                            @onclick="@(() => OnRepoSortChangeAsync(InboxFilterSortMode.Count))">PRs</button>
                    <button type="button"
                            class="sort-btn @(_repoSortMode == InboxFilterSortMode.Recent ? "active" : "")"
                            title="Sort by most recent upstream PR update."
                            @onclick="@(() => OnRepoSortChangeAsync(InboxFilterSortMode.Recent))">Recent</button>
                </div>
                <ul class="repo-list">
                    @foreach (var item in repoItems)
                    {
                        var isChecked = !item.Excluded;
                        <li>
                            <label>
                                <input type="checkbox"
                                       checked="@isChecked"
                                       @onchange="@(e => OnRepoToggleAsync(item.Name, (bool)e.Value!))" />
                                <span class="repo-name">@item.Name</span>
                                <span class="repo-count @(item.Count == 0 ? "zero" : "")">@item.Count</span>
                            </label>
                        </li>
                    }
                    @if (repoItems.Count == 0)
                    {
                        <li class="empty muted">No repos match.</li>
                    }
                </ul>
            </div>
        }
    </div>

    <div class="repo-filter">
        <button type="button"
                class="repo-pill @(_excludedAuthors.Count > 0 ? "active" : "") @(_authorFilterOpen ? "open" : "")"
                @onclick="ToggleAuthorFilterPopover"
                title="@AuthorFilterTooltip">
            @AuthorFilterPillLabel
            <span class="repo-pill-caret">▾</span>
        </button>
        @if (_authorFilterOpen)
        {
            <div class="repo-popover-backdrop" @onclick="CloseAuthorFilterPopover"></div>
            <div class="repo-popover" role="dialog" aria-label="Per-author filter">
                <input type="search"
                       class="repo-popover-search"
                       placeholder="Filter authors…"
                       @bind="_authorFilterSearch"
                       @bind:event="oninput" />
                @{
                    var authorItems = FilteredAuthorListItems;
                    var canHideVisibleAuthors = authorItems.Any(i => i.Count > 0 && !i.Excluded);
                }
                <div class="repo-popover-actions">
                    <button type="button"
                            class="link-like"
                            disabled="@(_excludedAuthors.Count == 0)"
                            @onclick="OnShowAllAuthorsAsync">Show all</button>
                    <button type="button"
                            class="link-like"
                            disabled="@(!canHideVisibleAuthors)"
                            title="Hide every author currently shown in this list."
                            @onclick="OnHideVisibleAuthorsAsync">Hide visible</button>
                    <span class="muted">@AuthorFilterStatusLine</span>
                </div>
                <div class="repo-popover-sort">
                    <span class="muted">Sort:</span>
                    <button type="button"
                            class="sort-btn @(_authorSortMode == InboxFilterSortMode.Count ? "active" : "")"
                            title="Sort by PR count, highest first."
                            @onclick="@(() => OnAuthorSortChangeAsync(InboxFilterSortMode.Count))">PRs</button>
                    <button type="button"
                            class="sort-btn @(_authorSortMode == InboxFilterSortMode.Recent ? "active" : "")"
                            title="Sort by most recent upstream PR update."
                            @onclick="@(() => OnAuthorSortChangeAsync(InboxFilterSortMode.Recent))">Recent</button>
                </div>
                <ul class="repo-list">
                    @foreach (var item in authorItems)
                    {
                        var isChecked = !item.Excluded;
                        <li>
                            <label>
                                <input type="checkbox"
                                       checked="@isChecked"
                                       @onchange="@(e => OnAuthorToggleAsync(item.Name, (bool)e.Value!))" />
                                <span class="repo-name">@item.DisplayLabel</span>
                                <span class="repo-count @(item.Count == 0 ? "zero" : "")">@item.Count</span>
                            </label>
                        </li>
                    }
                    @if (authorItems.Count == 0)
                    {
                        <li class="empty muted">No authors match.</li>
                    }
                </ul>
            </div>
        }
    </div>

    <label class="show-closed">
        <input type="checkbox" checked="@_showClosed"
               @onchange="@(e => OnShowClosedToggleAsync((bool)e.Value!))" />
        Show closed / merged
    </label>
    <label class="show-ignored">
        <input type="checkbox" checked="@_showIgnored"
               @onchange="@(e => OnShowIgnoredToggleAsync((bool)e.Value!))" />
        Show ignored
    </label>
    @if (!string.IsNullOrEmpty(_lastLaunchMessage))
    {
        <span class="muted">@_lastLaunchMessage</span>
    }
</div>

@{
    var consoles = Consoles.List();
}
@if (consoles.Count > 0)
{
    <div class="toolbar console-strip" role="group" aria-label="Review consoles">
        <span class="muted">@consoles.Count review console@(consoles.Count == 1 ? "" : "s") open:</span>
        <button type="button" class="link-like" @onclick="OnMinimizeAllConsoles"
                title="Minimize every tracked review console (does not close them).">
            Minimize all
        </button>
        <button type="button" class="link-like" @onclick="OnShowAllConsoles"
                title="Restore every tracked review console to the foreground.">
            Show all
        </button>
        <span class="muted">·</span>
        @foreach (var c in consoles)
        {
            var isVisible = c.IsVisible();
            <span class="console-pill" title="@($"Launched at {c.LaunchedAt.ToLocalTime():HH:mm}")">
                @c.DisplayTitle
                <button type="button" class="link-like"
                        @onclick="() => OnToggleConsole(c.RunId, !isVisible)"
                        title="@(isVisible ? "Minimize this console" : "Restore this console")">
                    @(isVisible ? "minimize" : "show")
                </button>
            </span>
        }
    </div>
}

@{
    var visible = VisibleRows;
}
@if (visible.Count == 0)
{
    @if (_rows.Count == 0)
    {
        <p class="empty">No PRs yet. The first fast-sync runs on startup; check back in a few seconds.</p>
    }
    else
    {
        <p class="empty">No rows match the current filters. Try toggling "Show closed / merged" or "Show ignored", re-enabling a source chip, or clearing the repo filter.</p>
    }
}
else
{
    <table class="pr-table">
        <thead>
            <tr>
                <th>Source</th>
                <th>Repo / PR</th>
                <th>Title</th>
                <th>Author</th>
                <th>Threads</th>
                <th>State</th>
                <th>Last sync</th>
                <th>Review</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in visible)
            {
                <tr class="@RowClasses(row)">
                    <td><span class="badge @SourceClass(row)">@SourceLabel(row)</span></td>
                    <td>
                        <a href="@row.Url" target="_blank" rel="noopener">
                            @row.DisplayRepo #@row.Number
                        </a>
                    </td>
                    <td class="title">@(row.Title ?? "")</td>
                    <td>@(row.AuthorLogin ?? "")</td>
                    <td>
                        @if (row.OpenThreadCount == 0)
                        {
                            <span class="muted">–</span>
                        }
                        else if (row.SourceKind == SourceKind.GitHub || row.SourceKind == SourceKind.GitHubEnterprise)
                        {
                            <a href="@($"/threads?url={Uri.EscapeDataString(row.Url)}")"
                               title="Manage and resolve threads">
                                @row.OpenThreadCount
                            </a>
                            @if (row.UnresolvedBotCount > 0)
                            {
                                <span class="muted"> (@row.UnresolvedBotCount bot)</span>
                            }
                            @if (row.LikelyDoneCount > 0)
                            {
                                <a href="@($"/threads?url={Uri.EscapeDataString(row.Url)}")"
                                   class="ready-pill"
                                   title="@row.LikelyDoneCount thread@(row.LikelyDoneCount == 1 ? "" : "s") have a 'done' / 'fixed' / 'addressed' / '+1' reply. Click to review and resolve.">
                                    ✓ @row.LikelyDoneCount ready
                                </a>
                            }
                        }
                        else
                        {
                            <span>@row.OpenThreadCount</span>
                            @if (row.UnresolvedBotCount > 0)
                            {
                                <span class="muted"> (@row.UnresolvedBotCount bot)</span>
                            }
                        }
                    </td>
                    <td>
                        <span class="badge @StatusClass(row.Status)">@StatusLabel(row.Status)</span>
                        @if (row.DisappearedAt is not null && row.Status == PullRequestStatus.Open)
                        {
                            <span class="badge disappeared-pill"
                                  title="You're no longer a requested reviewer on this PR (still open upstream). Ignore it to hide.">
                                no longer assigned
                            </span>
                        }
                    </td>
                    <td class="muted" title="@EnrichTooltip(row.EnrichState)">
                        @RelativeTime(row.LastSyncedAt)
                        @if (row.EnrichState != EnrichState.Enriched)
                        {
                            <span class="enrich-suffix"> · @row.EnrichState.ToString().ToLowerInvariant()</span>
                        }
                    </td>
                    <td>
                        @{
                            var run = _runMap.TryGetValue(row.Url, out var r) ? r : null;
                        }
                        @if (run is null)
                        {
                            <span class="muted">–</span>
                        }
                        else if (run.Findings is null)
                        {
                            <span class="badge enrich-basic" title="@run.RunDirectory">in progress</span>
                        }
                        else
                        {
                            var total = run.CriticalCount + run.HighCount + run.MediumCount + run.LowCount;
                            <span class="findings-counts"
                                  title="@($"run #{run.RunId} · {run.RunDirectory}")">
                                @if (run.CriticalCount > 0)
                                {
                                    <a class="findings-link sev-critical"
                                       href="@($"/review?url={Uri.EscapeDataString(row.Url)}&show=C")">C:@run.CriticalCount</a>
                                }
                                @if (run.HighCount > 0)
                                {
                                    <a class="findings-link sev-high"
                                       href="@($"/review?url={Uri.EscapeDataString(row.Url)}&show=H")">H:@run.HighCount</a>
                                }
                                @if (run.MediumCount > 0)
                                {
                                    <a class="findings-link sev-medium"
                                       href="@($"/review?url={Uri.EscapeDataString(row.Url)}&show=M")">M:@run.MediumCount</a>
                                }
                                @if (run.LowCount > 0)
                                {
                                    <a class="findings-link sev-low"
                                       href="@($"/review?url={Uri.EscapeDataString(row.Url)}&show=L")">L:@run.LowCount</a>
                                }
                                @if (total == 0)
                                {
                                    <a class="findings-link clean-pill"
                                       title="@CleanVerdict.BuildTooltip(run.Findings, DateTimeOffset.UtcNow)"
                                       href="@($"/review?url={Uri.EscapeDataString(row.Url)}")">✓ clean</a>
                                }
                                else
                                {
                                    var conv = ConvergenceVerdict.Compute(run.Findings);
                                    if (conv.State != ConvergenceState.Hidden)
                                    {
                                        <a class="convergence-badge @conv.CssClass"
                                           title="@conv.Tooltip"
                                           href="@($"/review?url={Uri.EscapeDataString(row.Url)}")">@conv.Glyph</a>
                                    }
                                }
                            </span>
                        }
                        @if (row.DriftKind == DriftKind.Ahead)
                        {
                            var url     = BuildCompareUrl(row);
                            var title   = $"+{row.DriftCount} commit{(row.DriftCount == 1 ? "" : "s")} since last review @ {ShortSha(row.LastReviewedHeadSha)}";
                            if (url is not null)
                            {
                                <a class="drift drift-ahead" href="@url" target="_blank" rel="noopener" title="@title">+@row.DriftCount</a>
                            }
                            else
                            {
                                <span class="drift drift-ahead" title="@title">+@row.DriftCount</span>
                            }
                        }
                        else if (row.DriftKind == DriftKind.ForcePushed)
                        {
                            var url     = BuildCompareUrl(row);
                            var title   = $"Force-push since last review @ {ShortSha(row.LastReviewedHeadSha)} — old HEAD no longer in history";
                            if (url is not null)
                            {
                                <a class="drift drift-forcepush" href="@url" target="_blank" rel="noopener" title="@title">⚠ force-push</a>
                            }
                            else
                            {
                                <span class="drift drift-forcepush" title="@title">⚠ force-push</span>
                            }
                        }
                    </td>
                    <td class="row-actions">
                        <button class="review" @onclick="() => OnReviewAsync(row)">Review</button>
                        <button class="ignore" title="@(row.IsIgnored ? "Unignore this PR" : "Ignore this PR")"
                                @onclick="() => OnToggleIgnoreAsync(row)">
                            @(row.IsIgnored ? "Unignore" : "Ignore")
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    // Visible chip definitions. Class corresponds to the value returned by
    // SourceClass(row). The persisted source_filter pref is a JSON array of
    // these class strings.
    private record SourceChip(string Class, string Label);
    private static readonly SourceChip[] SourceChips = new[]
    {
        new SourceChip("src-emu",    "EMU"),
        new SourceChip("src-public", "public"),
        new SourceChip("src-ghe",    "proxima"),
        new SourceChip("src-ado",    "ADO"),
    };

    private const string PrefShowClosed   = "inbox.show_closed";
    private const string PrefShowIgnored  = "inbox.show_ignored";
    private const string PrefSourceFilter = "inbox.source_filter";
    private const string PrefExcludedRepos = "inbox.excluded_repos";
    private const string PrefExcludedAuthors = "inbox.excluded_authors";
    private const string PrefAuthorSortMode = "inbox.author_sort_mode";
    private const string PrefRepoSortMode   = "inbox.repo_sort_mode";

    private IReadOnlyList<InboxRow> _rows = Array.Empty<InboxRow>();
    private IReadOnlyDictionary<string, ReviewRun> _runMap = new Dictionary<string, ReviewRun>();
    private string? _lastLaunchMessage;
    private bool _showClosed;
    private bool _showIgnored;
    private bool _refreshing;

    // Source classes that are currently enabled. Default = all known
    // chips on; loaded from prefs in OnInitializedAsync.
    private HashSet<string> _enabledSources =
        new(SourceChips.Select(c => c.Class), StringComparer.OrdinalIgnoreCase);

    // Per-repo denylist (DisplayRepo strings). Empty = no filter; default
    // for unknown repos is "visible" so a freshly opened PR in a new repo
    // never silently disappears from the inbox.
    private HashSet<string> _excludedRepos =
        new(StringComparer.OrdinalIgnoreCase);

    // Repo-filter popover UI state — not persisted.
    private bool _repoFilterOpen;
    private string _repoFilterSearch = string.Empty;

    // Per-author denylist (PR author login). Empty = no filter; default
    // for unknown authors is "visible", same opt-out shape as repos. Null
    // / empty author logins are bucketed under <see cref="UnknownAuthorKey"/>
    // so they can be filtered as a group.
    private HashSet<string> _excludedAuthors =
        new(StringComparer.OrdinalIgnoreCase);

    // Author-filter popover UI state — not persisted.
    private bool _authorFilterOpen;
    private string _authorFilterSearch = string.Empty;

    // Sort modes for the popovers. Persisted so the choice survives a
    // page reload. Defaults to Count to match the previous behavior.
    private InboxFilterSortMode _authorSortMode = InboxFilterSortMode.Count;
    private InboxFilterSortMode _repoSortMode = InboxFilterSortMode.Count;

    private const string UnknownAuthorKey = InboxFilters.UnknownAuthorKey;

    // Compiled IgnoredRepos regex list. Invalid patterns are dropped with
    // a debug log; we never crash the page over bad config.
    private List<Regex> _ignoredRepoRegexes = new();

    private string RowCountLabel
    {
        get
        {
            var visible = VisibleRows.Count;
            return visible == _rows.Count
                ? $"{_rows.Count} PR(s)"
                : $"{visible} shown · {_rows.Count} total";
        }
    }

    private string LastSyncLabel => State.LastSyncMessage ?? "Loading...";

    private bool IsSourceEnabled(string sourceClass) => _enabledSources.Contains(sourceClass);

    private bool RowMatchesIgnoredRepoRegex(InboxRow row)
    {
        if (_ignoredRepoRegexes.Count == 0) return false;
        foreach (var re in _ignoredRepoRegexes)
        {
            try { if (re.IsMatch(row.DisplayRepo)) return true; }
            catch { /* runtime regex error — ignore the pattern */ }
        }
        return false;
    }

    private bool RowIsHidden(InboxRow row) =>
        row.IsIgnored || RowMatchesIgnoredRepoRegex(row);

    /// <summary>
    /// Combines row-level state into the CSS class list. Ignored / hidden
    /// rows are dimmed and italicized; rows the user has been de-assigned
    /// from get a subtler demotion that keeps them legible.
    /// </summary>
    private string RowClasses(InboxRow row)
    {
        if (RowIsHidden(row)) return "row-hidden";
        if (row.DisappearedAt is not null && row.Status == PullRequestStatus.Open) return "row-disappeared";
        return "";
    }

    /// <summary>
    /// Build a fresh <see cref="InboxFilters"/> snapshot from the local
    /// UI state. The popovers update <c>_excludedRepos</c> / <c>_excludedAuthors</c>
    /// in place; this getter is the bridge to the shared filter pipeline
    /// used by <see cref="InboxSyncHostedService"/>.
    /// </summary>
    private InboxFilters CurrentFilters => InboxFilters.From(
        _showClosed,
        _showIgnored,
        _enabledSources,
        _excludedRepos,
        _excludedAuthors,
        _ignoredRepoRegexes,
        Config.Sources);

    private IReadOnlyList<InboxRow> VisibleRows
    {
        get
        {
            var filters = CurrentFilters;
            return _rows.Where(filters.ShouldShow).ToArray();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // First-run redirect: if no config file exists, kick the user to
        // /settings so they can add at least one source before doing
        // anything else. Without sources, the inbox would just sit empty.
        if (!ConfigSvc.ConfigFileExists())
        {
            Nav.NavigateTo("/settings", forceLoad: false);
            return;
        }

        State.Changed += OnStateChanged;
        Runs.Changed += OnStateChanged;
        Consoles.Changed += OnStateChanged;
        await LoadPrefsAsync();
        CompileIgnoredRepoRegexes();
        SnapshotAll();
    }

    private async Task LoadPrefsAsync()
    {
        try
        {
            _showClosed  = await Prefs.GetBoolAsync(PrefShowClosed, defaultValue: false);
            _showIgnored = await Prefs.GetBoolAsync(PrefShowIgnored, defaultValue: false);

            var rawSources = await Prefs.GetAsync(PrefSourceFilter);
            if (!string.IsNullOrWhiteSpace(rawSources))
            {
                try
                {
                    var arr = JsonSerializer.Deserialize<string[]>(rawSources);
                    if (arr is not null && arr.Length > 0)
                    {
                        _enabledSources = new HashSet<string>(arr, StringComparer.OrdinalIgnoreCase);
                    }
                }
                catch (Exception ex)
                {
                    Log.LogDebug(ex, "Could not parse {Key}; falling back to defaults.", PrefSourceFilter);
                }
            }

            var rawExcluded = await Prefs.GetAsync(PrefExcludedRepos);
            if (!string.IsNullOrWhiteSpace(rawExcluded))
            {
                try
                {
                    var arr = JsonSerializer.Deserialize<string[]>(rawExcluded);
                    if (arr is not null)
                    {
                        _excludedRepos = new HashSet<string>(arr, StringComparer.OrdinalIgnoreCase);
                    }
                }
                catch (Exception ex)
                {
                    Log.LogDebug(ex, "Could not parse {Key}; falling back to empty set.", PrefExcludedRepos);
                }
            }

            var rawExcludedAuthors = await Prefs.GetAsync(PrefExcludedAuthors);
            if (!string.IsNullOrWhiteSpace(rawExcludedAuthors))
            {
                try
                {
                    var arr = JsonSerializer.Deserialize<string[]>(rawExcludedAuthors);
                    if (arr is not null)
                    {
                        _excludedAuthors = new HashSet<string>(arr, StringComparer.OrdinalIgnoreCase);
                    }
                }
                catch (Exception ex)
                {
                    Log.LogDebug(ex, "Could not parse {Key}; falling back to empty set.", PrefExcludedAuthors);
                }
            }

            _authorSortMode = ParseSortMode(await Prefs.GetAsync(PrefAuthorSortMode), InboxFilterSortMode.Count);
            _repoSortMode   = ParseSortMode(await Prefs.GetAsync(PrefRepoSortMode),   InboxFilterSortMode.Count);
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "Loading UI prefs failed; using defaults.");
        }
    }

    private static InboxFilterSortMode ParseSortMode(string? raw, InboxFilterSortMode fallback)
    {
        if (string.IsNullOrWhiteSpace(raw)) return fallback;
        return Enum.TryParse<InboxFilterSortMode>(raw, ignoreCase: true, out var parsed)
            ? parsed
            : fallback;
    }

    private void CompileIgnoredRepoRegexes()
    {
        _ignoredRepoRegexes.Clear();
        // Delegate to the shared compiler so the regex timeout + error
        // policy stays consistent with the sync-side filter.
        foreach (var re in InboxFilters.CompileIgnoredRepoRegexes(Config.IgnoredRepos))
        {
            _ignoredRepoRegexes.Add(re);
        }
    }

    private async Task OnShowClosedToggleAsync(bool value)
    {
        _showClosed = value;
        try { await Prefs.SetBoolAsync(PrefShowClosed, value); }
        catch (Exception ex) { Log.LogDebug(ex, "Persist {Key} failed.", PrefShowClosed); }
    }

    private async Task OnShowIgnoredToggleAsync(bool value)
    {
        _showIgnored = value;
        try { await Prefs.SetBoolAsync(PrefShowIgnored, value); }
        catch (Exception ex) { Log.LogDebug(ex, "Persist {Key} failed.", PrefShowIgnored); }
    }

    private async Task OnSourceChipToggleAsync(string sourceClass, bool enabled)
    {
        if (enabled) _enabledSources.Add(sourceClass);
        else _enabledSources.Remove(sourceClass);
        try
        {
            await Prefs.SetAsync(PrefSourceFilter,
                JsonSerializer.Serialize(_enabledSources.ToArray()));
        }
        catch (Exception ex) { Log.LogDebug(ex, "Persist {Key} failed.", PrefSourceFilter); }
    }

    // ----- Per-repo filter helpers -------------------------------------

    /// <summary>
    /// Highest <see cref="InboxRow.LastUpstreamUpdatedAt"/> seen in
    /// <paramref name="rows"/>, or <c>null</c> if every row's value is
    /// missing. Used by the "Recent" sort mode on both filter popovers
    /// to demote groups with no observed upstream activity.
    /// </summary>
    private static DateTimeOffset? MaxRecentOrNull(IEnumerable<InboxRow> rows)
    {
        DateTimeOffset? best = null;
        foreach (var r in rows)
        {
            if (r.LastUpstreamUpdatedAt is null) continue;
            if (best is null || r.LastUpstreamUpdatedAt > best) best = r.LastUpstreamUpdatedAt;
        }
        return best;
    }

    private sealed record RepoFilterItem(
        string Name,
        int Count,
        bool Excluded,
        DateTimeOffset? MaxRecent) : IInboxFilterItem;

    /// <summary>
    /// Repos that <em>could</em> show up given the current source-chip /
    /// closed / ignored settings, with their post-source-filter PR counts.
    /// We do NOT apply <see cref="_excludedRepos"/> here so the popover
    /// always lists every repo the user could re-enable. Repos in the
    /// excluded set that no longer have any matching rows still appear
    /// with count = 0 so they're recoverable from the UI alone.
    /// </summary>
    private IReadOnlyList<RepoFilterItem> AllRepoFilterItems
    {
        get
        {
            var src = _rows.AsEnumerable();
            if (!_showClosed)
                src = src.Where(r => r.Status == PullRequestStatus.Open);
            if (_enabledSources.Count < SourceChips.Length)
                src = src.Where(r => ChipFilterPasses(r));
            if (!_showIgnored)
                src = src.Where(r => !RowIsHidden(r));

            var byName = src
                .GroupBy(r => r.DisplayRepo, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(
                    g => g.Key,
                    g => (Count: g.Count(), MaxRecent: MaxRecentOrNull(g)),
                    StringComparer.OrdinalIgnoreCase);

            // Surface any excluded repo that no longer has matching rows so
            // the user can still un-exclude it from the popover.
            foreach (var name in _excludedRepos)
            {
                if (!byName.ContainsKey(name)) byName[name] = (Count: 0, MaxRecent: null);
            }

            var items = byName
                .Select(kv => new RepoFilterItem(
                    kv.Key, kv.Value.Count, _excludedRepos.Contains(kv.Key), kv.Value.MaxRecent));

            return InboxFilterHelpers.Sort(items, _repoSortMode).ToList();
        }
    }

    private IReadOnlyList<RepoFilterItem> FilteredRepoListItems
    {
        get
        {
            var items = AllRepoFilterItems;
            if (string.IsNullOrWhiteSpace(_repoFilterSearch)) return items;
            var needle = _repoFilterSearch.Trim();
            return items
                .Where(i => i.Name.Contains(needle, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private string RepoFilterPillLabel
    {
        get
        {
            var items = AllRepoFilterItems;
            var (visible, hidden) = InboxFilterHelpers.CountsForPill(items);
            return hidden == 0
                ? $"Repos • {visible}"
                : $"Repos • {visible} / {hidden} hidden";
        }
    }

    private string RepoFilterTooltip
    {
        get
        {
            if (_excludedRepos.Count == 0) return "Filter inbox by repo.";
            var sample = _excludedRepos.OrderBy(x => x, StringComparer.OrdinalIgnoreCase).Take(8);
            var more = _excludedRepos.Count > 8 ? $", … (+{_excludedRepos.Count - 8} more)" : "";
            return "Hidden: " + string.Join(", ", sample) + more;
        }
    }

    private string RepoFilterStatusLine
    {
        get
        {
            var items = AllRepoFilterItems;
            var (visible, hidden) = InboxFilterHelpers.CountsForPill(items);
            var total = visible + hidden;
            return hidden == 0
                ? $"{total} repo(s)"
                : $"{hidden} of {total} hidden";
        }
    }

    private void ToggleRepoFilterPopover()
    {
        _repoFilterOpen = !_repoFilterOpen;
        if (!_repoFilterOpen) _repoFilterSearch = string.Empty;
    }

    private void CloseRepoFilterPopover()
    {
        _repoFilterOpen = false;
        _repoFilterSearch = string.Empty;
    }

    private async Task OnRepoToggleAsync(string repoName, bool visible)
    {
        if (string.IsNullOrWhiteSpace(repoName)) return;
        if (visible) _excludedRepos.Remove(repoName);
        else _excludedRepos.Add(repoName);
        await PersistExcludedReposAsync();
    }

    private async Task OnShowAllReposAsync()
    {
        if (_excludedRepos.Count == 0) return;
        _excludedRepos.Clear();
        await PersistExcludedReposAsync();
    }

    private async Task OnHideVisibleReposAsync()
    {
        var changed = false;
        foreach (var item in FilteredRepoListItems)
        {
            if (item.Count > 0 && !item.Excluded && _excludedRepos.Add(item.Name))
                changed = true;
        }
        if (changed) await PersistExcludedReposAsync();
    }

    private async Task OnRepoSortChangeAsync(InboxFilterSortMode mode)
    {
        if (_repoSortMode == mode) return;
        _repoSortMode = mode;
        try { await Prefs.SetAsync(PrefRepoSortMode, mode.ToString()); }
        catch (Exception ex) { Log.LogDebug(ex, "Persist {Key} failed.", PrefRepoSortMode); }
    }

    private async Task PersistExcludedReposAsync()
    {
        try
        {
            await Prefs.SetAsync(PrefExcludedRepos,
                JsonSerializer.Serialize(_excludedRepos.ToArray()));
        }
        catch (Exception ex) { Log.LogDebug(ex, "Persist {Key} failed.", PrefExcludedRepos); }
    }

    // ----- Per-author filter helpers -----------------------------------

    private sealed record AuthorFilterItem(
        string Name,
        string DisplayLabel,
        int Count,
        bool Excluded,
        DateTimeOffset? MaxRecent) : IInboxFilterItem;

    private static string AuthorKeyOf(InboxRow row) =>
        string.IsNullOrWhiteSpace(row.AuthorLogin) ? UnknownAuthorKey : row.AuthorLogin!;

    private static string AuthorDisplayLabel(string key) =>
        key == UnknownAuthorKey ? "(unknown)" : "@" + key;

    /// <summary>
    /// Authors that <em>could</em> show up given the current source-chip /
    /// closed / ignored / repo settings, with their post-source-filter PR
    /// counts. We do NOT apply <see cref="_excludedAuthors"/> here so the
    /// popover always lists every author the user could re-enable. Excluded
    /// authors with zero matching rows still appear with count = 0 so
    /// they're recoverable from the UI alone.
    /// </summary>
    private IReadOnlyList<AuthorFilterItem> AllAuthorFilterItems
    {
        get
        {
            var src = _rows.AsEnumerable();
            if (!_showClosed)
                src = src.Where(r => r.Status == PullRequestStatus.Open);
            if (_enabledSources.Count < SourceChips.Length)
                src = src.Where(r => ChipFilterPasses(r));
            if (_excludedRepos.Count > 0)
                src = src.Where(r => !_excludedRepos.Contains(r.DisplayRepo));
            if (!_showIgnored)
                src = src.Where(r => !RowIsHidden(r));

            var byKey = src
                .GroupBy(r => AuthorKeyOf(r), StringComparer.OrdinalIgnoreCase)
                .ToDictionary(
                    g => g.Key,
                    g => (Count: g.Count(), MaxRecent: MaxRecentOrNull(g)),
                    StringComparer.OrdinalIgnoreCase);

            foreach (var name in _excludedAuthors)
            {
                if (!byKey.ContainsKey(name)) byKey[name] = (Count: 0, MaxRecent: null);
            }

            var items = byKey
                .Select(kv => new AuthorFilterItem(
                    kv.Key, AuthorDisplayLabel(kv.Key), kv.Value.Count,
                    _excludedAuthors.Contains(kv.Key), kv.Value.MaxRecent));

            return InboxFilterHelpers.Sort(items, _authorSortMode).ToList();
        }
    }

    private IReadOnlyList<AuthorFilterItem> FilteredAuthorListItems
    {
        get
        {
            var items = AllAuthorFilterItems;
            if (string.IsNullOrWhiteSpace(_authorFilterSearch)) return items;
            var needle = _authorFilterSearch.Trim();
            return items
                .Where(i => i.Name.Contains(needle, StringComparison.OrdinalIgnoreCase)
                         || i.DisplayLabel.Contains(needle, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private string AuthorFilterPillLabel
    {
        get
        {
            var items = AllAuthorFilterItems;
            var (visible, hidden) = InboxFilterHelpers.CountsForPill(items);
            return hidden == 0
                ? $"Authors • {visible}"
                : $"Authors • {visible} / {hidden} hidden";
        }
    }

    private string AuthorFilterTooltip
    {
        get
        {
            if (_excludedAuthors.Count == 0) return "Filter inbox by PR author.";
            var sample = _excludedAuthors
                .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
                .Take(8)
                .Select(AuthorDisplayLabel);
            var more = _excludedAuthors.Count > 8 ? $", … (+{_excludedAuthors.Count - 8} more)" : "";
            return "Hidden: " + string.Join(", ", sample) + more;
        }
    }

    private string AuthorFilterStatusLine
    {
        get
        {
            var items = AllAuthorFilterItems;
            var (visible, hidden) = InboxFilterHelpers.CountsForPill(items);
            var total = visible + hidden;
            return hidden == 0
                ? $"{total} author(s)"
                : $"{hidden} of {total} hidden";
        }
    }

