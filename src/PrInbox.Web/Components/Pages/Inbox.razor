    private void OpenTagPopover(string url)
    {
        // Toggle: clicking the same row closes the popover; clicking a
        // different row's "+" moves the popover. Reset the create form so
        // a half-typed tag from a previous row doesn't bleed across.
        if (string.Equals(_openTagPopoverForUrl, url, StringComparison.Ordinal))
        {
            CloseTagPopover();
            return;
        }
        _openTagPopoverForUrl = url;
        _newTagName = string.Empty;
        _newTagColor = TagPalette[0];
    }

    private void CloseTagPopover()
    {
        _openTagPopoverForUrl = null;
        _newTagName = string.Empty;
    }

    /// <summary>
    /// Refresh the live tags on a single PR after a mutation, then upsert
    /// the row so the chip strip re-renders without waiting for the next
    /// background sync.
    /// </summary>
    private async Task RefreshRowTagsAsync(InboxRow row)
    {
        try
        {
            var fresh = await TagRepo.GetTagsForPrAsync(row.Url, CancellationToken.None);
            State.Upsert(row with { Tags = fresh });
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "Refresh tags for {Url} failed", row.Url);
        }
    }

    private async Task OnTogglePrTagAsync(InboxRow row, string tagName, bool isChecked)
    {
        try
        {
            if (isChecked)
            {
                await TagRepo.AddTagToPrAsync(row.Url, tagName, DateTimeOffset.UtcNow, CancellationToken.None);
            }
            else
            {
                await TagRepo.RemoveTagFromPrAsync(row.Url, tagName, CancellationToken.None);
            }
            await RefreshRowTagsAsync(row);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Toggle tag {Tag} for {Url} failed", tagName, row.Url);
            _lastLaunchMessage = $"Could not update tag: {ex.Message}";
        }
    }

    private async Task OnCreateTagAndAttachAsync(InboxRow row)
    {
        var name = _newTagName.Trim();
        if (string.IsNullOrEmpty(name)) return;
        try
        {
            var now = DateTimeOffset.UtcNow;
            await TagRepo.CreateTagAsync(name, _newTagColor, now, CancellationToken.None);
            await TagRepo.AddTagToPrAsync(row.Url, name, now, CancellationToken.None);
            _newTagName = string.Empty;
            await ReloadTagsAsync();
            await RefreshRowTagsAsync(row);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Create+attach tag {Tag} for {Url} failed", name, row.Url);
            _lastLaunchMessage = $"Could not create tag: {ex.Message}";
        }
    }

    private async Task OnNewTagKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e, InboxRow row)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_newTagName))
        {
            await OnCreateTagAndAttachAsync(row);
        }
        else if (e.Key == "Escape")
        {
            CloseTagPopover();
        }
    }

    private record GroupRow(string name, string? color, IReadOnlyList<InboxRow> rows);

    /// <summary>
    /// Bucket the visible rows by the active <see cref="_groupBy"/> mode.
    /// When mode is Tag a PR with multiple tags appears in EACH matching
    /// group (Gmail-label semantics) — confirmed with the user. A
    /// synthetic "★ Starred" group is materialized from flagged_at, and
    /// rows with no tag and no star fall into "untagged" so nothing is
    /// silently dropped.
    /// </summary>
    private List<GroupRow> ComputeGroups(IReadOnlyList<InboxRow> visible)
    {
        if (_groupBy == GroupByMode.None)
        {
            return new List<GroupRow> { new("", null, visible) };
        }

        // Preserve creation order of tags by walking _allTags first;
        // unknown tags (shouldn't happen — but defensive) get appended.
        var ordered = new List<string>();
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var t in _allTags) { ordered.Add(t.Name); seen.Add(t.Name); }
        var groups = new Dictionary<string, GroupRow>(StringComparer.OrdinalIgnoreCase);

        // Synthetic Starred group from flagged_at.
        var starred = visible.Where(r => r.IsFlagged).ToList();
        if (starred.Count > 0)
        {
            groups["★ Starred"] = new GroupRow("★ Starred", "#f59e0b", starred);
            ordered.Insert(0, "★ Starred");
            seen.Add("★ Starred");
        }

        foreach (var row in visible)
        {
            foreach (var tag in row.TagsSafe)
            {
                if (!groups.TryGetValue(tag.Name, out var g))
                {
                    g = new GroupRow(tag.Name, tag.Color, new List<InboxRow>());
                    groups[tag.Name] = g;
                    if (seen.Add(tag.Name)) ordered.Add(tag.Name);
                }
                ((List<InboxRow>)g.rows).Add(row);
            }
        }

        var untagged = visible.Where(r => !r.HasTags && !r.IsFlagged).ToList();
        if (untagged.Count > 0)
        {
            groups["untagged"] = new GroupRow("untagged", null, untagged);
            ordered.Add("untagged");
        }

        var result = new List<GroupRow>(ordered.Count);
        foreach (var name in ordered)
        {
            if (groups.TryGetValue(name, out var g) && g.rows.Count > 0) result.Add(g);
        }
        return result;
    }

    private async Task OnToggleFlagAsync(InboxRow row)
    {
        try
        {
            if (row.IsFlagged)
            {
                await PrRepo.UnflagAsync(row.Url, CancellationToken.None);
                State.Upsert(row with { FlaggedAt = null });
            }
            else
            {
                var when = DateTimeOffset.UtcNow;
                await PrRepo.FlagAsync(row.Url, when, CancellationToken.None);
                State.Upsert(row with { FlaggedAt = when });
            }
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Toggle flag for {Url} failed", row.Url);
            _lastLaunchMessage = $"Could not update flag: {ex.Message}";
        }
    }

    private async Task OnToggleDoneAsync(InboxRow row)
    {
        try
        {
            if (row.IsMarkedDone)
            {
                await PrRepo.ClearDoneAsync(row.Url, CancellationToken.None);
                State.Upsert(row with { MarkedDoneHeadSha = null, MarkedDoneAt = null });
            }
            else
            {
                // Anchor "done" at the SHA we have in hand. If we have no
                // snapshot yet (CurrentHeadSha unknown), fall back to the
                // last-reviewed SHA, then to a sentinel. The IsMarkedDone
                // computed prop handles the "current SHA unknown" case
                // defensively — see InboxRow.IsMarkedDone.
                var sha = row.CurrentHeadSha
                          ?? row.LastReviewedHeadSha
                          ?? "unknown";
                var when = DateTimeOffset.UtcNow;
                await PrRepo.MarkDoneAsync(row.Url, sha, when, CancellationToken.None);
                State.Upsert(row with { MarkedDoneHeadSha = sha, MarkedDoneAt = when });
            }
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Toggle done for {Url} failed", row.Url);
            _lastLaunchMessage = $"Could not update done state: {ex.Message}";
        }
    }

    private async Task OnSourceChipToggleAsync(string sourceClass, bool enabled)
