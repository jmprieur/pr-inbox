    private async Task OnToggleIgnoreAsync(InboxRow row)
    {
        var next = !row.IsIgnored;
        try
        {
            await PrRepo.SetIgnoredAsync(row.Url, next, CancellationToken.None);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "SetIgnored({Url},{Next}) failed", row.Url, next);
            _lastLaunchMessage = $"Could not update ignore state: {ex.Message}";
            return;
        }
        // Push the new row through InboxState so the page (and any other
        // open inbox tab) sees it immediately, without waiting for the
        // next sync cycle to re-snapshot.
        State.Upsert(row with { IsIgnored = next });
    }

    private void OnStateChanged()
    {
        SnapshotAll();
        InvokeAsync(StateHasChanged);
    }

    private void SnapshotAll()
    {
        _rows = State.CurrentRows;
        _runMap = Runs.Snapshot();
    }

    private async Task OnReviewAsync(InboxRow row)
    {
        try
        {
            _lastLaunchMessage = await Launcher.LaunchAsync(row.Url, CancellationToken.None);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Review launcher threw");
            _lastLaunchMessage = $"Launcher error: {ex.Message}";
        }
    }

    private void OnToggleConsole(long runId, bool show)
    {
        try { Consoles.Toggle(runId, show); }
        catch (Exception ex) { Log.LogWarning(ex, "Toggle console for run {RunId} failed.", runId); }
    }

    private void OnMinimizeAllConsoles()
    {
        try { Consoles.ToggleAll(show: false); }
        catch (Exception ex) { Log.LogWarning(ex, "Minimize-all consoles failed."); }
    }

    private void OnShowAllConsoles()
    {
        try { Consoles.ToggleAll(show: true); }
        catch (Exception ex) { Log.LogWarning(ex, "Show-all consoles failed."); }
    }

    private async Task OnRefreshAsync()
    {
        if (_refreshing) return;
        _refreshing = true;
        try
        {
            var started = await Sync.TriggerNowAsync(CancellationToken.None);
            if (!started)
            {
                _lastLaunchMessage = "Sync already in progress.";
            }
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Manual refresh failed");
            _lastLaunchMessage = $"Refresh error: {ex.Message}";
        }
        finally
        {
            _refreshing = false;
        }
    }

    // Derive the visible badge text the same way SourceClass derives the
    // chip class: prefer the configured SourceConfig (host + identity)
    // when we can find one for the row's id; fall back to id-string
    // parsing for rows whose source has been removed from config.
    // Keeping these two helpers in lock-step prevents the chip-vs-label
    // mismatch that Jean-Marc hit on the new install where an explicit
    // EMU identity source (e.g. gh.com:jmprieur_microsoft) was correctly
    // filtered by the EMU chip but visually labelled "public".
    private string SourceLabel(InboxRow row)
    {
        foreach (var sc in Config.Sources)
        {
            if (string.Equals(sc.Id, row.SourceId, StringComparison.OrdinalIgnoreCase))
            {
                return InboxFilters.LabelForClass(InboxFilters.ClassifyConfig(sc), sc.Id);
            }
        }
        return SourceLabelFromId(row.SourceId);
    }

    private static string SourceLabelFromId(string sourceId) => sourceId switch
    {
        "gh.com:emu"    => "EMU",
        "gh.com"        => "public",
        "gh.com:public" => "public",
        var id when id.StartsWith("gh.com:", StringComparison.Ordinal)  => "public",
        var id when id.StartsWith("ghe.", StringComparison.Ordinal)  => "proxima",
        var id when id.StartsWith("ado:", StringComparison.Ordinal)  => "ado",
        _ => sourceId,
    };

    // The chip class is derived from the configured SourceConfig when
    // we can find one matching the row's id — this is the authoritative
    // (kind, host, identity) path. Falls back to the legacy id-string
    // parser for rows whose source has been removed from the config or
    // when running against a test fixture that bypasses configuration.
    private string SourceClass(InboxRow row)
    {
        foreach (var sc in Config.Sources)
        {
            if (string.Equals(sc.Id, row.SourceId, StringComparison.OrdinalIgnoreCase))
            {
                return InboxFilters.ClassifyConfig(sc);
            }
        }
        return InboxFilters.SourceClassOf(row.SourceId);
    }

    // Chip filter for the dropdown population helpers (AllRepoFilterItems,
    // AllAuthorFilterItems). Mirrors InboxFilters.ShouldShowCore: only
    // hide rows whose class is one the UI actually surfaces as a chip.
    // A row whose class is "src-other" can't be toggled (no chip exists
    // for it), so it must remain visible regardless of which chips the
    // user has unchecked. Without this, a user with a single gh.com
    // source whose id maps to an unknown class would see the repo/author
    // dropdowns go empty the moment they uncheck any chip.
    private bool ChipFilterPasses(InboxRow row)
    {
        var cls = SourceClass(row);
        if (!InboxFilters.KnownSourceClasses.Contains(cls)) return true;
        return _enabledSources.Contains(cls);
    }

    private static string StatusLabel(PullRequestStatus s) => s switch
    {
        PullRequestStatus.Open         => "open",
        PullRequestStatus.Closed       => "closed",
        PullRequestStatus.Merged       => "merged",
        PullRequestStatus.Inaccessible => "inaccessible",
        _                              => s.ToString().ToLowerInvariant(),
    };

    private static string StatusClass(PullRequestStatus s) => s switch
    {
        PullRequestStatus.Open         => "status-open",
        PullRequestStatus.Closed       => "status-closed",
        PullRequestStatus.Merged       => "status-merged",
        PullRequestStatus.Inaccessible => "status-inaccessible",
        _                              => "status-other",
    };

    private static string EnrichTooltip(EnrichState s) => s switch
    {
        EnrichState.Enriched => "enrich: threads, iterations, bot signals loaded",
        EnrichState.Basic    => "enrich: list-tier only; details still loading",
        _                    => "enrich: not yet synced",
    };

    private static string RelativeTime(DateTimeOffset when)
    {
        var delta = DateTimeOffset.UtcNow - when;
        if (delta.TotalSeconds < 60) return "just now";
        if (delta.TotalMinutes < 60) return $"{(int)delta.TotalMinutes}m ago";
        if (delta.TotalHours   < 24) return $"{(int)delta.TotalHours}h ago";
        return $"{(int)delta.TotalDays}d ago";
    }

    private static string ShortSha(string? sha)
    {
        if (string.IsNullOrEmpty(sha)) return "?";
        return sha.Length >= 7 ? sha[..7] : sha;
    }

    private static string? BuildCompareUrl(InboxRow row)
    {
        if (string.IsNullOrEmpty(row.LastReviewedHeadSha) || string.IsNullOrEmpty(row.CurrentHeadSha)) return null;
        var info = new DriftInfo(row.DriftKind, row.DriftCount, row.LastReviewedHeadSha, row.CurrentHeadSha);
        return info.BuildCompareUrl(row.Url);
    }

    public void Dispose()
    {
        State.Changed -= OnStateChanged;
        Runs.Changed -= OnStateChanged;
        Consoles.Changed -= OnStateChanged;
    }
}
