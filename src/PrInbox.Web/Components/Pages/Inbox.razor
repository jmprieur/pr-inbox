    private AgeSortMode _ageSortMode = AgeSortMode.None;

    private const string UnknownAuthorKey = InboxFilters.UnknownAuthorKey;

    // Compiled IgnoredRepos regex list. Invalid patterns are dropped with
    // a debug log; we never crash the page over bad config.
    private List<Regex> _ignoredRepoRegexes = new();

    private string RowCountLabel
    {
        get
        {
            var visible = VisibleRows.Count;
            return visible == _rows.Count
                ? $"{_rows.Count} PR(s)"
                : $"{visible} shown · {_rows.Count} total";
        }
    }

    private string LastSyncLabel => State.LastSyncMessage ?? "Loading...";

    private bool IsSourceEnabled(string sourceClass) => _enabledSources.Contains(sourceClass);

    private bool RowMatchesIgnoredRepoRegex(InboxRow row)
    {
        if (_ignoredRepoRegexes.Count == 0) return false;
        foreach (var re in _ignoredRepoRegexes)
        {
            try { if (re.IsMatch(row.DisplayRepo)) return true; }
            catch { /* runtime regex error — ignore the pattern */ }
        }
        return false;
    }

    private bool RowIsHidden(InboxRow row) =>
        row.IsIgnored || RowMatchesIgnoredRepoRegex(row);

    /// <summary>
    /// Combines row-level state into the CSS class list. Ignored / hidden
    /// rows are dimmed and italicized; rows the user has been de-assigned
    /// from get a subtler demotion that keeps them legible.
    /// </summary>
    private string RowClasses(InboxRow row)
    {
        if (RowIsHidden(row)) return "row-hidden";
        if (row.DisappearedAt is not null && row.Status == PullRequestStatus.Open) return "row-disappeared";
        return "";
    }

    /// <summary>
    /// Build a fresh <see cref="InboxFilters"/> snapshot from the local
    /// UI state. The popovers update <c>_excludedRepos</c> / <c>_excludedAuthors</c>
    /// in place; this getter is the bridge to the shared filter pipeline
    /// used by <see cref="InboxSyncHostedService"/>.
    /// </summary>
    private InboxFilters CurrentFilters => InboxFilters.From(
        _showClosed,
        _showIgnored,
        _showDone,
        _onlyFlagged,
        _enabledSources,
        _excludedRepos,
        _excludedAuthors,
        _ignoredRepoRegexes,
        Config.Sources);

    private IReadOnlyList<InboxRow> VisibleRows
    {
        get
        {
            var filters = CurrentFilters;
            return _rows.Where(filters.ShouldShow).ToArray();
        }
    }

    /// <summary>
    /// Count of rows currently hidden ONLY because they're marked done
    /// (i.e. would be visible if "Show done" were on). Drives the "Show
    /// done (N)" toolbar label so the user can tell at a glance how many
    /// rows are snoozed.
    /// </summary>
    private int HiddenDoneCount
    {
        get
        {
            if (_showDone) return 0;
            // Reuse the current filter but flip ShowDone on, then count
            // the rows that are marked-done within that pool. Anything
            // hidden by the other filters (closed/ignored/source/repo/
            // author) is already off the dashboard regardless.
            var allowDone = CurrentFilters with { ShowDone = true };
            var count = 0;
            foreach (var r in _rows)
            {
                if (r.IsMarkedDone && allowDone.ShouldShow(r)) count++;
            }
            return count;
        }
    }

    /// <summary>
    /// Total flagged rows currently in the in-memory set. Shown next to
    /// the "Show only flagged" label so the user always knows how many
    /// PRs they're tracking. Counts the underlying flag, not the filter
    /// output, so the badge stays meaningful regardless of which row is
    /// otherwise hidden.
    /// </summary>
    private int FlaggedCount => _rows.Count(r => r.IsFlagged);

    protected override async Task OnInitializedAsync()
    {
        // First-run redirect: if no config file exists, kick the user to
        // /settings so they can add at least one source before doing
        // anything else. Without sources, the inbox would just sit empty.
        if (!ConfigSvc.ConfigFileExists())
        {
            Nav.NavigateTo("/settings", forceLoad: false);
            return;
        }

        State.Changed += OnStateChanged;
        Runs.Changed += OnStateChanged;
        Consoles.Changed += OnStateChanged;
        await LoadPrefsAsync();
        await ReloadTagsAsync();
        CompileIgnoredRepoRegexes();
        SnapshotAll();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Fire on every render: if the user just came back from /review, the
        // JS pulls the stashed URL out of localStorage, scrolls the row into
        // view, and pulses it for ~2s -- then clears the storage so we
        // don't re-flash on subsequent renders. No-op if storage is empty.
        try { await Js.InvokeVoidAsync("prInboxLastVisited.flash"); }
        catch (Exception ex) { Log.LogDebug(ex, "flash last-visited failed"); }

        if (!firstRender) return;
        // If the user just changed config on /settings (added/removed a
        // source), trigger an out-of-band fast+enrich pass so the inbox
        // reflects the new world without waiting up to one full
        // background interval. Fire-and-forget so the first render isn't
        // blocked; the existing Changed events will repaint when rows
        // land. ConsumeConfigChanged is single-shot per NoteConfigChanged.
        if (Sync.ConsumeConfigChanged())
        {
            _ = Sync.TriggerNowAsync(CancellationToken.None);
        }
    }

    private async Task LoadPrefsAsync()
    {
        try
        {
            _showClosed  = await Prefs.GetBoolAsync(PrefShowClosed, defaultValue: false);
            _showIgnored = await Prefs.GetBoolAsync(PrefShowIgnored, defaultValue: false);
            _showDone    = await Prefs.GetBoolAsync(PrefShowDone, defaultValue: false);
            _onlyFlagged = await Prefs.GetBoolAsync(PrefOnlyFlagged, defaultValue: false);
            var gbRaw = await Prefs.GetAsync(PrefGroupBy);
            _groupBy = string.Equals(gbRaw, "tag", StringComparison.OrdinalIgnoreCase)
                ? GroupByMode.Tag
                : GroupByMode.None;

            var rawSources = await Prefs.GetAsync(PrefSourceFilter);
            if (!string.IsNullOrWhiteSpace(rawSources))
            {
                try
                {
                    var arr = JsonSerializer.Deserialize<string[]>(rawSources);
                    if (arr is not null && arr.Length > 0)
                    {
                        _enabledSources = new HashSet<string>(arr, StringComparer.OrdinalIgnoreCase);
                    }
                }
                catch (Exception ex)
                {
                    Log.LogDebug(ex, "Could not parse {Key}; falling back to defaults.", PrefSourceFilter);
                }
            }

            var rawExcluded = await Prefs.GetAsync(PrefExcludedRepos);
            if (!string.IsNullOrWhiteSpace(rawExcluded))
            {
                try
                {
                    var arr = JsonSerializer.Deserialize<string[]>(rawExcluded);
                    if (arr is not null)
                    {
                        _excludedRepos = new HashSet<string>(arr, StringComparer.OrdinalIgnoreCase);
                    }
                }
                catch (Exception ex)
                {
                    Log.LogDebug(ex, "Could not parse {Key}; falling back to empty set.", PrefExcludedRepos);
                }
            }

            var rawExcludedAuthors = await Prefs.GetAsync(PrefExcludedAuthors);
            if (!string.IsNullOrWhiteSpace(rawExcludedAuthors))
            {
                try
                {
                    var arr = JsonSerializer.Deserialize<string[]>(rawExcludedAuthors);
                    if (arr is not null)
                    {
                        _excludedAuthors = new HashSet<string>(arr, StringComparer.OrdinalIgnoreCase);
                    }
                }
                catch (Exception ex)
                {
                    Log.LogDebug(ex, "Could not parse {Key}; falling back to empty set.", PrefExcludedAuthors);
                }
            }

            _authorSortMode = ParseSortMode(await Prefs.GetAsync(PrefAuthorSortMode), InboxFilterSortMode.Count);
            _repoSortMode   = ParseSortMode(await Prefs.GetAsync(PrefRepoSortMode),   InboxFilterSortMode.Count);
            _ageSortMode    = ParseAgeSortMode(await Prefs.GetAsync(PrefAgeSortMode));
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "Loading UI prefs failed; using defaults.");
        }
    }

    private static InboxFilterSortMode ParseSortMode(string? raw, InboxFilterSortMode fallback)
    {
        if (string.IsNullOrWhiteSpace(raw)) return fallback;
        return Enum.TryParse<InboxFilterSortMode>(raw, ignoreCase: true, out var parsed)
            ? parsed
            : fallback;
    }

    private static AgeSortMode ParseAgeSortMode(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return AgeSortMode.None;
        return Enum.TryParse<AgeSortMode>(raw, ignoreCase: true, out var parsed)
            ? parsed
            : AgeSortMode.None;
    }

    // Direction glyph shown next to the "Age" header. ▲ = oldest first
    // (ascending age-at-top is the oldest open PR), ▼ = newest first.
    private string AgeSortGlyph => _ageSortMode switch
    {
        AgeSortMode.OldestFirst => " ▲",
        AgeSortMode.NewestFirst => " ▼",
        _ => "",
    };

    /// <summary>
    /// Cycle the Age column sort on header click: None → OldestFirst →
    /// NewestFirst → None. Persisted so it survives a reload.
    /// </summary>
    private async Task OnAgeHeaderClickAsync()
    {
        _ageSortMode = _ageSortMode switch
        {
            AgeSortMode.None => AgeSortMode.OldestFirst,
            AgeSortMode.OldestFirst => AgeSortMode.NewestFirst,
            _ => AgeSortMode.None,
        };
        try { await Prefs.SetAsync(PrefAgeSortMode, _ageSortMode.ToString()); }
        catch (Exception ex) { Log.LogDebug(ex, "Persist {Key} failed.", PrefAgeSortMode); }
    }

    /// <summary>
    /// Compact age label for the inbox "Age" column: how long the PR has been
    /// open upstream. Clamps negative deltas (clock skew / bad source data) to
    /// "just now" and renders "–" when the opened date hasn't been recorded.
    /// </summary>
    private static string AgeLabel(DateTimeOffset? createdAt)
    {
        if (createdAt is not { } opened) return "–";
        var delta = DateTimeOffset.UtcNow - opened;
        if (delta < TimeSpan.Zero) return "just now";
        if (delta.TotalSeconds < 60) return "just now";
        if (delta.TotalMinutes < 60) return $"{(int)delta.TotalMinutes}m";
        if (delta.TotalHours   < 24) return $"{(int)delta.TotalHours}h";
        if (delta.TotalDays    < 30) return $"{(int)delta.TotalDays}d";
        if (delta.TotalDays    < 365) return $"{(int)(delta.TotalDays / 30)}mo";
        return $"{(int)(delta.TotalDays / 365)}y";
    }

    private static string AgeTooltip(DateTimeOffset? createdAt)
        => createdAt is { } opened
            ? $"Opened {opened.LocalDateTime:yyyy-MM-dd HH:mm}"
            : "Opened date not recorded yet — will appear after the next sync.";


    private void CompileIgnoredRepoRegexes()
    {
        _ignoredRepoRegexes.Clear();
        // Delegate to the shared compiler so the regex timeout + error
        // policy stays consistent with the sync-side filter.
        foreach (var re in InboxFilters.CompileIgnoredRepoRegexes(Config.IgnoredRepos))
        {
            _ignoredRepoRegexes.Add(re);
        }
    }

